---
import { Icon } from "astro-icon/components";

interface Props {
  src: string;
  alt: string;
  className?: string; // Outer container class
  imageClass?: string; // Inner image frame class (like skew-y-1)
  showArrow?: boolean;
}

const {
  src,
  alt,
  className = "",
  imageClass = "",
  showArrow = false,
} = Astro.props;
---

<div class={`decorative-image-area relative group ${className}`}>
  <!-- Floating Accent Decor -->
  <div
    class="absolute -top-4 -left-4 md:-top-6 md:-left-6 w-32 h-32 bg-orange-600/10 rounded-full blur-3xl group-hover:bg-orange-600/20 transition-colors duration-700"
  >
  </div>
  <div
    class="absolute -bottom-6 -right-6 md:-bottom-10 md:-right-10 w-40 h-40 bg-blue-600/5 rounded-full blur-3xl"
  >
  </div>

  <!-- Main Image Frame -->
  <div
    class={`relative z-10 rounded-md overflow-hidden shadow-2xl transition-transform duration-700 ${imageClass} group-hover:skew-y-0`}
  >
    <img
      src={src}
      alt={alt}
      class="w-full h-auto object-cover scale-105 group-hover:scale-100 transition-transform duration-1000"
      width="800"
      height="600"
    />
    <!-- Overlay Gradient -->
    <div
      class="absolute inset-0 bg-gradient-to-t from-slate-900/40 to-transparent opacity-60 group-hover:opacity-20 transition-opacity"
    >
    </div>

    <!-- Big Arrow Overlay (Optional) -->
    {
      showArrow && (
        <div class="absolute bottom-6 right-6 md:bottom-10 md:right-10 w-32 h-32 md:w-64 md:h-64 text-white opacity-90 pointer-events-none transition-transform duration-700 group-hover:scale-110 group-hover:translate-x-2 group-hover:translate-y-2">
          <Icon
            name="lucide:arrow-down-right"
            class="w-full h-full stroke-[1.5] drop-shadow-md"
          />
        </div>
      )
    }
  </div>

  <!-- Decorative Border Frame -->
  <div
    class="absolute inset-0 border-2 border-orange-600/30 rounded-md translate-x-2 translate-y-2 md:translate-x-4 md:translate-y-4 -z-10 group-hover:translate-x-1 md:group-hover:translate-x-2 group-hover:translate-y-1 md:group-hover:translate-y-2 transition-transform duration-700"
  >
  </div>
</div>
