---
interface Props {
  variant?: "primary" | "secondary" | "outline" | "ghost";
  size?: "sm" | "md" | "lg";
  className?: string;
  href?: string;
  [key: string]: any;
}

const {
  variant = "primary",
  size = "md",
  className = "",
  href,
  ...rest
} = Astro.props;

const variants = {
  primary:
    "bg-orange-500 text-white hover:bg-orange-600 shadow-sm font-bold uppercase tracking-wider transition-colors duration-200",
  secondary:
    "bg-slate-900 text-white hover:bg-slate-800 shadow-sm font-bold uppercase tracking-wider transition-colors duration-200",
  outline:
    "border border-slate-200 text-slate-800 hover:border-orange-500 hover:text-orange-500 font-bold uppercase tracking-wider transition-colors duration-200 bg-white",
  ghost:
    "bg-transparent  hover:bg-slate-50 font-bold uppercase tracking-wider transition-colors duration-200",
};

const sizes = {
  sm: "px-6 py-2.5 text-xs",
  md: "px-8 py-3.5 text-[13px]",
  lg: "px-10 py-4 text-sm",
};

const Element = href ? "a" : "button";
---

<Element
  href={href}
  class={`inline-flex items-center justify-center cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed  ${variants[variant]} ${sizes[size]} ${className}`}
  {...rest}
>
  <slot />
</Element>
