---
interface Props {
  variant?: 'primary' | 'success' | 'warning' | 'error' | 'neutral';
  className?: string;
}

const { variant = 'neutral', className = '' } = Astro.props;

const variants = {
  primary: 'bg-indigo-50 text-indigo-700 border-indigo-100',
  success: 'bg-emerald-50 text-emerald-700 border-emerald-100',
  warning: 'bg-amber-50 text-amber-700 border-amber-100',
  error: 'bg-rose-50 text-rose-700 border-rose-100',
  neutral: 'bg-gray-50 text-gray-700 border-gray-200',
};
---

<span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold border ${variants[variant]} ${className}`}>
  <slot />
</span>
