---
import { Icon } from 'astro-icon/components';

const testimonials = [
  {
    quote: "Đó là một trải nghiệm tuyệt vời. Đội ngũ NextTax là một đối tác đáng tin cậy; họ đã dành thời gian cần thiết để hiểu rõ hoạt động và nhu cầu của chúng tôi. Sự chuyên nghiệp của họ đã giúp dự án đi đúng hướng.",
    author: "Dana Wade Sr",
    company: "Allianz Inc",
    image: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&q=80&w=400"
  },
  {
    quote: "Chúng tôi rất hài lòng với dịch vụ kế toán trọn gói của NextTax. Họ không chỉ làm tốt phần việc chuyên môn mà còn tư vấn rất tận tâm về các rủi ro tài chính tiềm ẩn.",
    author: "Nguyễn Văn Hùng",
    company: "H-Tech Solutions",
    image: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?auto=format&fit=crop&q=80&w=400"
  },
  {
    quote: "Quy trình làm việc chuyên nghiệp, minh bạch và nhanh chóng. NextTax giúp doanh nghiệp của tôi tiết kiệm được rất nhiều thời gian và chi phí vận hành.",
    author: "Trần Thị Lan",
    company: "Lan Furniture",
    image: "https://images.unsplash.com/photo-1580489944761-15a19d654956?auto=format&fit=crop&q=80&w=400"
  }
];

const logos = [
  { name: 'TECHBRAND', class: 'font-black tracking-tighter' },
  { name: 'SMATRICS', class: 'font-black tracking-widest uppercase' },
  { name: 'Bayern', class: 'font-serif italic font-bold' },
  { name: 'acrevis', class: 'font-bold tracking-tight lowercase' },
  { name: 'SAUTER', class: 'font-extrabold uppercase' },
  { name: 'EVOLVED', class: 'font-black italic uppercase' },
];
---

<section class="py-24 md:py-32 bg-white" id="testimonial-section">
  <div class="container mx-auto px-4 max-w-7xl">
    
    <!-- Testimonial Section -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-16 lg:gap-24 items-center mb-24 cursor-default">
      
      <!-- Left: Overlapping Circles -->
      <div class="testimonial-circles relative w-full max-w-[320px] h-[240px] mx-auto lg:mx-0 hidden md:block">
        <!-- Quote Circle -->
        <div class="absolute left-0 top-1/2 -translate-y-1/2 w-48 h-48 rounded-full border border-slate-200 bg-white flex items-center justify-center z-0">
          <Icon name="lucide:quote" class="w-12 h-12 text-slate-800 -translate-x-4" />
        </div>
        <!-- Image Circle - Controlled by Swiper -->
        <div class="absolute right-0 top-1/2 -translate-y-1/2 w-48 h-48 rounded-full overflow-hidden z-10 shadow-2xl border-4 border-white testimonial-image-container">
          <img src={testimonials[0].image} alt="Customer" class="w-full h-full object-cover main-testimonial-img">
        </div>
      </div>

      <!-- Right: Content Swiper -->
      <div class="relative min-w-0 w-full">
        <div class="space-y-8">
          <p class="testimonial-label text-rose-500 font-bold tracking-wide text-sm uppercase">
            Khách hàng nghĩ gì về dịch vụ của chúng tôi!
          </p>

          <div class="swiper testimonial-swiper">
            <div class="swiper-wrapper">
              {testimonials.map((t) => (
                <div class="swiper-slide cursor-grab active:cursor-grabbing">
                  <div class="flex flex-col justify-between h-full space-y-8">
                    <h3 class="testimonial-quote text-xl md:text-2xl lg:text-3xl font-extrabold text-slate-900 leading-[1.4] tracking-tight min-h-[150px] md:min-h-[120px]">
                      "{t.quote}"
                    </h3>

                    <!-- Author block pushed right to leave space for absolute arrows -->
                    <div class="testimonial-author flex items-center ml-24 md:ml-32 min-h-[50px]">
                      <div class="flex flex-col">
                        <span class="font-bold text-slate-900 text-lg leading-tight">{t.author}</span>
                        <span class="text-sm text-slate-500">{t.company}</span>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- External Minimalist Navigation -->
        <div class="absolute bottom-0 left-0 flex items-center gap-6 text-slate-400 testimonial-nav z-10 h-[50px]">
          <button class="swiper-prev hover:text-slate-900 transition-colors">
            <Icon name="lucide:arrow-left" class="w-[22px] h-[22px] stroke-[1.5]" />
          </button>
          <button class="swiper-next hover:text-slate-900 transition-colors">
            <Icon name="lucide:arrow-right" class="w-[22px] h-[22px] stroke-[1.5]" />
          </button>
        </div>
      </div>
      
    </div>

    </div>

  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Navigation, EffectFade } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/effect-fade';
  import { gsap } from 'gsap';
  import { fadeIn } from '../animations/fadeIn';

  const initTestimonial = () => {
    const section = document.getElementById('testimonial-section');
    if (!section) return;

    // --- GSAP Entrance ---
    gsap.fromTo('.testimonial-circles',
      { opacity: 0, scale: 0.7, rotate: -10 },
      {
        opacity: 1, scale: 1, rotate: 0, duration: 1, ease: 'back.out(1.5)',
        scrollTrigger: { trigger: section, start: 'top 75%', toggleActions: 'play none none none' }
      }
    );

    fadeIn('.testimonial-label', 0, -20);
    fadeIn('.testimonial-swiper', 0.2, 40);
    fadeIn('.testimonial-nav', 0.4, 20);

    // --- Swiper Testimonial ---
    const swiper = new Swiper('.testimonial-swiper', {
      modules: [Navigation, EffectFade],
      effect: 'fade',
      fadeEffect: { crossFade: true },
      speed: 800,
      navigation: {
        nextEl: '.swiper-next',
        prevEl: '.swiper-prev',
      },
      on: {
        slideChange: (s) => {
          // Update the circle image based on active slide index
          const testimonials = [
            "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&q=80&w=400",
            "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?auto=format&fit=crop&q=80&w=400",
            "https://images.unsplash.com/photo-1580489944761-15a19d654956?auto=format&fit=crop&q=80&w=400"
          ];
          const imgEl = document.querySelector('.main-testimonial-img') as HTMLImageElement;
          if (imgEl) {
            gsap.to(imgEl, {
              opacity: 0,
              scale: 0.8,
              duration: 0.3,
              onComplete: () => {
                imgEl.src = testimonials[s.realIndex];
                gsap.to(imgEl, { opacity: 1, scale: 1, duration: 0.4, ease: 'back.out(1.5)' });
              }
            });
          }
        }
      }
    });
  };

  initTestimonial();
  document.addEventListener('astro:page-load', initTestimonial);
</script>
