---
import { Icon } from 'astro-icon/components';
import Button from '../ui/Button.astro';

const stats = [
  { value: 50, suffix: '+', label: 'Chuyên gia trình độ cao phục vụ.' },
  { value: 1034, suffix: '+', label: 'Hồ sơ quyết toán thành công trong 5 năm.' },
  { value: 63, suffix: '', label: 'Tỉnh thành trên toàn quốc được hỗ trợ.' },
  { value: 100, suffix: '%', label: 'Sự hài lòng từ khách hàng.' },
];
---

<section class="py-16 lg:py-32 bg-white overflow-hidden" id="about-preview-section">
  <div class="container mx-auto px-4 max-w-7xl">
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-24">
      
      <!-- Left Column -->
      <div class="flex flex-col gap-16">
        <div class="space-y-4">
          <p class="about-label text-orange-500 font-bold tracking-wide uppercase text-sm">
            Chiến lược toàn cầu thiết kế để giải quyết thách thức tương lai.
          </p>
          <h2 class="about-heading text-2xl md:text-3xl lg:text-4xl font-black text-slate-900 leading-[1.1] tracking-tight">
            Chúng Tôi Xây Dựng Niềm Tin Và Duy Trì Mối Quan Hệ Bền Vững!
          </h2>
        </div>

        <div class="about-image relative max-w-[80%] mt-8 group h-[500px]">
          <!-- Background arrow vectors (Decorative) -->
          <div class="absolute -right-20 top-1/2 -translate-y-1/2 w-48 h-48 opacity-5 -z-10 text-slate-900">
            <Icon name="lucide:arrow-up" class="w-full h-full" />
          </div>

          <!-- Cutout Square Effect (Top Left) -->
          <div class="absolute -top-1 -left-1 w-20 h-20 bg-white z-10 transition-all duration-500 group-hover:w-10 group-hover:h-10"></div>
          
          <img 
            src="https://images.unsplash.com/photo-1560250097-0b93528c311a?auto=format&fit=crop&q=75&w=800" 
            alt="Doanh nhân nghe điện thoại" 
            class="w-full h-full object-cover grayscale-[20%] hover:grayscale-0 transition-all duration-700"
            width="800"
            height="1000"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>

      <!-- Right Column -->
      <div class="flex flex-col gap-10 lg:pt-24">
        <div class="about-text-block space-y-6">
          <h3 class="text-2xl font-bold text-slate-900">
            Chúng tôi mang lại kết quả chất lượng cao nhất.
          </h3>
          <div class="space-y-4 text-slate-500 leading-relaxed text-[15px]">
            <p>
              Chúng tôi là một công ty tư vấn với hơn 10 năm kinh nghiệm trong nhiều lĩnh vực, hỗ trợ sự phát triển tài chính của hàng nghìn doanh nghiệp. Đội ngũ của chúng tôi hoạt động trên khắp các thị trường, giúp bạn thiết lập một kế toán tinh gọn đáp ứng thực tế kinh doanh của mình.
            </p>
            <p>
              Cho dù bạn muốn tối ưu hóa hiệu suất dòng tiền hay giảm thiểu rủi ro khi quyết toán thuế. Chúng tôi thấu hiểu đội ngũ đằng sau sự thành công của công ty và tin tưởng rằng đầu tư theo cách này sẽ truyền sức mạnh cho nguồn vốn của khách hàng.
            </p>
          </div>
          
          <!-- Signature area -->
          <div class="about-signature pt-2">
            <!-- Authentic handwriting signature image -->
            <div class="w-48 opacity-70 mix-blend-multiply">
              <img src="https://7oroof.com/demos/allianz/assets/images/about/signature.png" alt="Signature" class="w-full h-auto object-contain" loading="lazy" decoding="async" />
            </div>
          </div>
        </div>

        <!-- Animated Stats List -->
        <div class="flex flex-col w-full border-t border-slate-100 mt-4" id="stats-container">
          {stats.map((stat, index) => (
            <div class="stat-row flex flex-col sm:flex-row sm:items-center py-6 border-b border-slate-100 gap-4 sm:gap-12 transition-colors hover:bg-slate-50">
              <div class="text-3xl md:text-4xl font-extrabold text-slate-900 sm:w-32 flex items-center">
                <!-- Data attributes for JS counting -->
                <span class="counter-value" data-target={stat.value}>0</span>
                <span>{stat.suffix}</span>
              </div>
              <div class="text-slate-700 font-bold text-sm md:text-base flex-1">
                {stat.label}
              </div>
            </div>
          ))}
        </div>

        <div class="about-cta-btn pt-6">
          <Button variant="primary" size="lg" className="bg-orange-500 hover:bg-orange-600 text-white rounded-none font-bold uppercase text-sm tracking-wider px-8 border-none" href="/about">
            Xem thêm về chúng tôi <Icon name="lucide:arrow-up-right" class="w-4 h-4 ml-2 inline-block" />
          </Button>
        </div>
        
      </div>
      
    </div>
  </div>
</section>

<script>
  import { fadeIn, staggerReveal, clipPathReveal } from '../animations/fadeIn';

  const initAboutPreviewAnim = () => {
    fadeIn('.about-label', 0, -30);
    fadeIn('.about-heading', 0.2);
    clipPathReveal('.about-image', 0.4);
    fadeIn('.about-text-block', 0.5);
    fadeIn('.about-signature', 0.6, 20);
    staggerReveal('.stat-row', 0.12, 0.7);
    fadeIn('.about-cta-btn', 0.8);

    // --- Number Counter Animation (Keep custom logic as it's specialized) ---
    const container = document.getElementById('stats-container');
    if (!container) return;

    const counters = container.querySelectorAll('.counter-value');
    let hasAnimated = false;

    const startCounting = () => {
      counters.forEach((counter) => {
        const targetElement = counter as HTMLElement;
        const target = parseFloat(targetElement.getAttribute('data-target') || '0');
        const duration = 2000;
        const stepTime = Math.abs(Math.floor(duration / 60));
        let current = 0;
        const increment = target / (duration / stepTime);

        const timer = setInterval(() => {
          current += increment;
          if (current >= target) {
            targetElement.innerText = target.toLocaleString('en-US');
            clearInterval(timer);
          } else {
            targetElement.innerText = Math.ceil(current).toLocaleString('en-US');
          }
        }, stepTime);
      });
    };

    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting && !hasAnimated) {
        hasAnimated = true;
        startCounting();
        observer.disconnect();
      }
    }, { threshold: 0.1 });

    observer.observe(container);
  };

  initAboutPreviewAnim();
  document.addEventListener('astro:page-load', initAboutPreviewAnim);
</script>


