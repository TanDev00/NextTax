---
import { Icon } from "astro-icon/components";
import DecorativeImage from "../../ui/DecorativeImage.astro";
import SectionHeading from "../../ui/SectionHeading.astro";
import type { AboutPageData } from "../../../types/wordpress";

interface Props {
  /** Matches `AboutPageData.core_values` from WordPress / about page. */
  data?: AboutPageData["core_values"];
}

const { data } = Astro.props;

const coreValues = [
  {
    title: "Chuyên nghiệp",
    description: data?.coreValues?.professional || "",
    icon: "lucide:shield-check",
    color: "text-blue-600",
    bg: "bg-blue-50",
    border: "border-blue-100/80",
  },
  {
    title: "Uy tín",
    description: data?.coreValues?.reputation || "",
    icon: "lucide:award",
    color: "text-orange-600",
    bg: "bg-orange-50",
    border: "border-orange-100/80",
  },
  {
    title: "Cam kết",
    description: data?.coreValues?.commit || "",
    icon: "lucide:handshake",
    color: "text-emerald-600",
    bg: "bg-emerald-50",
    border: "border-emerald-100/80",
  },
  {
    title: "Sáng tạo",
    description: data?.coreValues?.creative || "",
    icon: "lucide:lightbulb",
    color: "text-amber-600",
    bg: "bg-amber-50",
    border: "border-amber-100/80",
  },
];
---

<section class="py-20 bg-slate-50/50 overflow-hidden" id="company-identity">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="identity-values-row mb-16 border-slate-100">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-8">
        {
          coreValues.map((val) => (
            <div
              class={`flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left gap-4 md:gap-5 p-4 rounded-md border shadow-sm hover:shadow-md transition-all duration-300 group min-w-0 ${val.bg} ${val.border}`}
            >
              <div
                class={`shrink-0 w-12 h-12 rounded-md bg-white/90 shadow-sm ${val.color} flex items-center justify-center group-hover:scale-110 group-hover:rotate-6 transition-transform duration-500`}
              >
                <Icon name={val.icon} class="w-6 h-6" />
              </div>
              <div class="min-w-0 w-full sm:flex-1">
                <h5 class="font-bold  mb-1 text-sm md:text-base">
                  {val.title}
                </h5>
                <p
                  class=" text-[11px] md:text-[11px] leading-normal truncate"
                  title={val.description}
                >
                  {val.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
    <div
      class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-20 items-center mb-16 lg:mb-24"
    >
      <!-- Left: Decorative Image -->
      <DecorativeImage
        src={data?.image?.node?.sourceUrl || "/images/company-identity.png"}
        alt={data?.title || "NextTax Office"}
        className="identity-image-area"
        imageClass="skew-y-1"
      />

      <!-- Right: Mission & Vision Stack -->
      <div class="flex flex-col gap-8 identity-content-area">
        <SectionHeading
          badge={data?.sub_title || ""}
          title={data?.title || ""}
          subtitle={data?.description || ""}
        />

        <div class="space-y-6">
          <!-- Sứ mệnh card -->
          <div class="identity-card-item group">
            <div
              class="relative rounded-md p-[1.5px] overflow-hidden bg-white shadow-lg transition-all duration-300 hover:shadow-xl"
            >
              <div
                class="absolute -inset-full opacity-0 group-hover:opacity-100 transition-opacity duration-700 z-0"
              >
                <div
                  class="absolute inset-0 bg-[conic-gradient(from_0deg_at_50%_50%,transparent_0%,transparent_60%,#3b82f6_80%,#60a5fa_100%)] animate-[spin_4s_linear_infinite]"
                >
                </div>
              </div>
              <div
                class="relative rounded-md bg-white z-10 p-5 md:p-6 flex items-start gap-4 md:gap-6 overflow-hidden"
              >
                <div
                  class="p-3 rounded-md bg-blue-50 text-blue-600 group-hover:scale-110 transition-transform shrink-0"
                >
                  <Icon name="lucide:target" class="w-8 h-8" />
                </div>
                <div>
                  <h4 class="text-xl font-bold  mb-2">Sứ Mệnh</h4>
                  <p class=" text-sm leading-relaxed">
                    {data?.mission || ""}
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Tầm nhìn card -->
          <div class="identity-card-item group">
            <div
              class="relative rounded-md p-[1.5px] overflow-hidden bg-white shadow-lg transition-all duration-300 hover:shadow-xl"
            >
              <div
                class="absolute -inset-full opacity-0 group-hover:opacity-100 transition-opacity duration-700 z-0"
              >
                <div
                  class="absolute inset-0 bg-[conic-gradient(from_0deg_at_50%_50%,transparent_0%,transparent_60%,#10b981_80%,#34d399_100%)] animate-[spin_4s_linear_infinite]"
                >
                </div>
              </div>
              <div
                class="relative rounded-md bg-white z-10 p-5 md:p-6 flex items-start gap-4 md:gap-6 overflow-hidden"
              >
                <div
                  class="p-3 rounded-md bg-emerald-50 text-emerald-600 group-hover:scale-110 transition-transform shrink-0"
                >
                  <Icon name="lucide:eye" class="w-8 h-8" />
                </div>
                <div>
                  <h4 class="text-xl font-bold  mb-2">
                    Tầm Nhìn
                  </h4>
                  <p class=" text-sm leading-relaxed">
                    {data?.vision || ""}
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { fadeIn, staggerReveal } from "../../animations/fadeIn";

  gsap.registerPlugin(ScrollTrigger);

  const initIdentity = () => {
    // Entrance Animations
    gsap.from(".identity-image-area", {
      x: -60,
      opacity: 0,
      duration: 1.2,
      ease: "power3.out",
      scrollTrigger: { trigger: "#company-identity", start: "top 75%" },
    });

    gsap.from(".identity-content-area", {
      x: 60,
      opacity: 0,
      duration: 1.2,
      ease: "power3.out",
      scrollTrigger: { trigger: "#company-identity", start: "top 75%" },
    });

    staggerReveal(".identity-card-item", 0.2, 0.5);
    fadeIn(".identity-values-row", 0.8, 30);
  };

  initIdentity();
  document.addEventListener("astro:page-load", initIdentity);
</script>
