---
import { Icon } from "astro-icon/components";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Dịch Vụ",
  description = "Giải pháp pháp lý và tài chính trọn gói giúp doanh nghiệp tối ưu vận hành và tuân thủ pháp luật một cách dễ dàng.",
  image = "https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&q=80&w=2000",
} = Astro.props;
---

<section
  class="relative w-full h-[60vh] min-h-[500px] flex items-center justify-center"
  id="services-page-hero"
>
  <div class="absolute inset-0">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover"
    />
    <div
      class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/70 to-orange-900/50 mix-blend-multiply"
    >
    </div>
    <div class="absolute inset-0 bg-black/30"></div>
  </div>

  <div class="relative z-10 text-center px-4 mt-20  mx-auto">
    <h1
      class="page-hero-title text-5xl md:text-7xl font-bold text-white mb-6 tracking-tight leading-[1.15]"
    >
      {title}
    </h1>
    <p
      class="page-hero-desc text-lg md:text-xl text-white/90 max-w-3xl mx-auto mb-8 font-medium leading-relaxed"
    >
      {description}
    </p>
    <div
      class="flex items-center justify-center gap-3 text-white/90 text-sm md:text-base font-medium"
    >
      <a href="/" class="hover:text-white transition-colors">Trang chủ</a>
      <Icon name="lucide:chevron-right" class="w-4 h-4 opacity-70" />
      <span class="font-bold text-white">Dịch vụ</span>
    </div>
  </div>
</section>

<script>
  import { fadeIn } from "../../animations/fadeIn";

  const initHeroAnim = () => {
    fadeIn(".page-hero-title", 0);
    fadeIn(".page-hero-desc", 0.2);
  };

  initHeroAnim();
  document.addEventListener("astro:page-load", initHeroAnim);
</script>
