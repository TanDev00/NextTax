---
import { Icon } from 'astro-icon/components';
import type { HeroSlide } from '../../../services/wordpress';

interface Props {
  slides: HeroSlide[];
}

const { slides: heroSlides } = Astro.props;

const slides = (heroSlides || []).map((slide: HeroSlide) => ({
  title: slide.title,
  subtitle: slide.subtitle,
  image: slide.image?.node?.sourceUrl || '',
}));
---

<section class="relative w-full h-screen min-h-[600px] bg-slate-900 group" id="hero-section">
  <div class="swiper hero-swiper w-full h-full">
    <div class="swiper-wrapper">
      {slides.map((slide, index) => (
        <div class="swiper-slide relative w-full h-full">
          <!-- Background Image with Gradient Overlay -->
          <div class="absolute inset-0">
            <img 
              src={slide.image} 
              alt={slide.title} 
              class="w-full h-full object-cover hero-bg-img" 
              width="1200" 
              height="800"
              fetchpriority={index === 0 ? 'high' : undefined}
              loading={index === 0 ? 'eager' : 'lazy'}
              decoding={index === 0 ? 'sync' : 'async'}
            />
            <div class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/60 to-transparent"></div>
          </div>
          
          <!-- Content - flex column to push bottom bar down -->
          <div class="relative container mx-auto px-6 h-full flex flex-col justify-center pb-48 md:pb-40">
            <div class="max-w-3xl space-y-6 pt-20">
              <p class="hero-subtitle text-white/80 font-semibold tracking-wider uppercase text-sm md:text-base">
                {slide.subtitle}
              </p>
              <h1 class="hero-title text-4xl md:text-5xl lg:text-6xl font-black text-white leading-[1.2] md:leading-[1.1] tracking-tight">
                {slide.title}
              </h1>
              
              <div class="pt-6 md:pt-8 flex items-center hero-cta">
                <!-- Round arrow button style -->
                <a href="/contact" class="w-16 h-16 md:w-20 md:h-20 rounded-full border border-white/50 flex items-center justify-center text-white hover:bg-white hover:text-slate-900 transition-colors group/btn">
                  <Icon name="lucide:arrow-up-right" class="w-6 h-6 md:w-8 md:h-8 group-hover/btn:translate-x-1 group-hover/btn:-translate-y-1 transition-transform" />
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Swiper Navigation Bottom Controls -->
    <div class="absolute bottom-6 md:bottom-10 left-0 w-full z-10">
      <div class="container mx-auto px-6">
        <div class="hero-bottom-bar flex flex-col md:flex-row md:items-center justify-between gap-4 md:gap-6 border-t border-white/20 pt-5 md:pt-6">
          <div class="flex-1 pr-6">
            <h3 class="text-white font-bold text-base md:text-lg mb-1 md:mb-2 leading-snug">We help our clients achieve their goals</h3>
            <p class="text-white/60 text-xs md:text-sm">Providing expert consulting services</p>
          </div>
          <div class="flex gap-3 md:gap-4 self-start md:self-auto">
            <button class="swiper-button-prev-custom w-12 h-12 rounded-full flex items-center justify-center text-white hover:bg-white/10 transition-colors border border-white/10 md:border-transparent bg-white/5 md:bg-transparent backdrop-blur-sm">
              <Icon name="lucide:chevron-left" class="w-5 h-5 md:w-6 md:h-6" />
            </button>
            <button class="swiper-button-next-custom w-12 h-12 rounded-full flex items-center justify-center text-white hover:bg-white/10 transition-colors border border-white/10 md:border-transparent bg-white/5 md:bg-transparent backdrop-blur-sm">
              <Icon name="lucide:chevron-right" class="w-5 h-5 md:w-6 md:h-6" />
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Navigation, Autoplay, EffectFade } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/effect-fade';
  import { gsap } from 'gsap';
  import { fadeIn } from '../../animations/fadeIn';

  const initHero = () => {
    // --- GSAP Hero entrance animation ---
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    // Initial states (hidden)
    gsap.set('.hero-subtitle', { opacity: 0, y: 40 });
    gsap.set('.hero-title', { opacity: 0, y: 60, clipPath: 'inset(0 0 100% 0)' });
    gsap.set('.hero-cta', { opacity: 0, y: 30, scale: 0.8 });
    gsap.set('.hero-bottom-bar', { opacity: 0, y: 30 });

    tl.to('.hero-subtitle', { opacity: 1, y: 0, duration: 0.8, delay: 0.3 })
      .to('.hero-title', { opacity: 1, y: 0, clipPath: 'inset(0 0 0% 0)', duration: 1.2 }, '-=0.5')
      .to('.hero-cta', { opacity: 1, y: 0, scale: 1, duration: 0.8 }, '-=0.6')
      .to('.hero-bottom-bar', { opacity: 1, y: 0, duration: 0.8 }, '-=0.5');

    // Subtle parallax on hero background
    const heroSection = document.getElementById('hero-section');
    if (heroSection) {
      window.addEventListener('scroll', () => {
        const scrollY = window.scrollY;
        const heroHeight = heroSection.offsetHeight;
        if (scrollY < heroHeight) {
          const imgs = heroSection.querySelectorAll('.hero-bg-img') as NodeListOf<HTMLElement>;
          imgs.forEach(img => {
            img.style.transform = `translateY(${scrollY * 0.3}px) scale(1.1)`;
          });
        }
      });
    }

    // --- Swiper ---
    new Swiper('.hero-swiper', {
      modules: [Navigation, Autoplay, EffectFade],
      effect: 'fade',
      fadeEffect: { crossFade: true },
      speed: 1000,
      autoplay: {
        delay: 6000,
        disableOnInteraction: false,
      },
      navigation: {
        nextEl: '.swiper-button-next-custom',
        prevEl: '.swiper-button-prev-custom',
      },
      loop: true,
      on: {
        slideChangeTransitionStart: () => {
          // Animate text in on slide change
          gsap.fromTo('.swiper-slide-active .hero-subtitle', 
            { opacity: 0, y: 30 }, 
            { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out', delay: 0.2 }
          );
          gsap.fromTo('.swiper-slide-active .hero-title', 
            { opacity: 0, y: 50, clipPath: 'inset(0 0 100% 0)' }, 
            { opacity: 1, y: 0, clipPath: 'inset(0 0 0% 0)', duration: 1, ease: 'power2.out', delay: 0.3 }
          );
          gsap.fromTo('.swiper-slide-active .hero-cta', 
            { opacity: 0, scale: 0.8 }, 
            { opacity: 1, scale: 1, duration: 0.7, ease: 'back.out(1.4)', delay: 0.6 }
          );
        }
      }
    });
  };

  initHero();
  document.addEventListener('astro:page-load', initHero);
</script>

<style>
  .hero-bg-img {
    transform: scale(1.1);
    will-change: transform;
  }
</style>
