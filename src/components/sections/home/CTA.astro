---
import { Icon } from "astro-icon/components";
import Button from "../../ui/Button.astro";

interface Props {
  heading: string;
  description: string;
  background: string;
}

const { heading, description, background } = Astro.props;
---

<section
  class="relative w-full py-16 md:py-20 flex items-center justify-center overflow-hidden"
  id="cta-section"
>
  <!-- Full-width background image -->
  <div class="absolute inset-0 z-0">
    <img
      src={background}
      alt="CTA Background"
      class="cta-bg w-full h-full object-cover object-center grayscale-[30%]"
      width="1200"
      height="800"
      loading="lazy"
      decoding="async"
    />
    <!-- Heavy Dark overlay to match screenshot mood -->
    <div class="absolute inset-0 bg-slate-900/85"></div>
  </div>

  <div
    class="relative z-10 container mx-auto px-4 text-center flex flex-col items-center"
  >
    <div class="max-w-3xl space-y-6">
      <h2
        class="cta-heading text-white text-2xl md:text-4xl lg:text-5xl font-black tracking-tight leading-tight"
      >
        {heading}
      </h2>

      <p
        class="cta-desc text-white/90 text-[17px] md:text-xl font-medium leading-relaxed"
        set:html={description}
      >
      </p>
    </div>

    <!-- Button keeps the exact requested variant styling from Button component -->
    <div class="cta-button pt-10">
      <div class="flex justify-center pt-4">
        <a
          href="/contact"
          class="group relative inline-flex items-center gap-3 px-8 py-4 bg-orange-600 text-white rounded-full font-bold text-lg overflow-hidden transition-all duration-300 hover:shadow-2xl hover:shadow-orange-900/20 hover:-translate-y-1 active:scale-95"
        >
          <!-- Background Glow Effect on Hover -->
          <div
            class="absolute inset-0 bg-gradient-to-r from-orange-600 to-orange-400 opacity-0 group-hover:opacity-100 transition-opacity duration-300 -z-10"
          >
          </div>

          Đăng ký tư vấn miễn phí
          <Icon
            name="lucide:arrow-right"
            class="w-6 h-6 group-hover:translate-x-1 transition-transform"
          />
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { fadeIn } from "../../animations/fadeIn";

  const initCTAAnim = () => {
    const section = document.getElementById("cta-section");
    if (!section) return;

    // Parallax background (specialized logic)
    gsap.fromTo(
      ".cta-bg",
      { scale: 1.15 },
      {
        scale: 1,
        ease: "none",
        scrollTrigger: {
          trigger: section,
          start: "top bottom",
          end: "bottom top",
          scrub: true,
        },
      },
    );

    // Reusable animations
    fadeIn(".cta-heading", 0, 40); // Custom y offset
    fadeIn(".cta-desc", 0.2);
    fadeIn(".cta-button", 0.4, 30);
  };

  initCTAAnim();
  document.addEventListener("astro:page-load", initCTAAnim);
</script>
