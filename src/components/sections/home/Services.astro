---
import ServiceCard from "../../ui/ServiceCard.astro";
import SectionHeading from "../../ui/SectionHeading.astro";
import { getSlugFromUrl } from "../../../lib/utils";

interface Props {
  badge: string;
  title: string;
  services: any[];
}

const { badge, title, services } = Astro.props;
const safeServices = services || [];
---

<section class="py-16 lg:py-24 bg-[#FAFAFA]" id="services-section">
  <div class="container mx-auto px-4 max-w-7xl">
    <SectionHeading
      badge={badge}
      title={title}
      class="mb-16"
      badgeClass="services-label"
      titleClass="services-heading"
    />

    <!-- Cards Grid -->
    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-stretch pt-4"
    >
      {
        safeServices.map((service) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            iconName={service.iconName}
            features={
              service.tags
                ? service.tags.split(",").map((tag: any) => tag.trim())
                : []
            }
            backgroundImage={service.backgroundImage?.node?.sourceUrl}
            slug={
              service.slug?.url ? getSlugFromUrl(service.slug?.url, "/") : "/"
            }
          />
        ))
      }
    </div>
  </div>
</section>

<script>
  import { fadeIn, staggerReveal } from "../../animations/fadeIn";

  const initServicesAnim = () => {
    fadeIn(".services-label", 0, -30);
    fadeIn(".services-heading", 0.2);
    // Lưu ý: class service-card nằm trong component ServiceCard
    staggerReveal(".service-card", 0.15);
  };

  initServicesAnim();
  document.addEventListener("astro:page-load", initServicesAnim);
</script>
