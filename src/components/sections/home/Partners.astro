---
import { Partner } from "../../../types/wordpress";

interface Props {
  partners: Partner[];
}

const { partners } = Astro.props;
let safePartners = partners || [];

// Thủ thuật: Nhân bản logo để đảm bảo Swiper Loop hoạt động mượt mà khi có ít đối tác
if (safePartners.length > 0 && safePartners.length < 10) {
  safePartners = [...safePartners, ...safePartners, ...safePartners];
}
---

<section
  class="py-10 md:py-16 bg-white border-t border-slate-100"
  id="partners-section"
>
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="swiper partner-logo-swiper overflow-hidden">
      <div class="swiper-wrapper items-center">
        {
          safePartners.map((partner) => (
            <div class="swiper-slide !w-auto">
              <div class="partner-logo px-8 md:px-12 flex items-center justify-center text-slate-300 hover: transition-colors duration-500 cursor-pointer">
                <div class="flex items-center justify-center">
                  {partner.logo?.node?.sourceUrl ? (
                    <img
                      src={partner.logo.node.sourceUrl}
                      alt={partner.name}
                      class="h-7 md:h-10 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-500"
                    />
                  ) : (
                    <span class="text-lg md:text-xl font-bold whitespace-nowrap">
                      {partner.name}
                    </span>
                  )}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import { Autoplay } from "swiper/modules";
  import "swiper/css";
  import { fadeIn } from "../../animations/fadeIn";

  const initPartners = () => {
    // Entrance animation
    fadeIn(".partner-logo-swiper", 0.2, 30);

    // Continuous loop Swiper
    new Swiper(".partner-logo-swiper", {
      modules: [Autoplay],
      slidesPerView: "auto",
      loop: true,
      centeredSlides: true,
      speed: 6000,
      autoplay: {
        delay: 0,
        disableOnInteraction: false,
        pauseOnMouseEnter: true,
      },
      allowTouchMove: true,
      grabCursor: true,
    });
  };

  initPartners();
  document.addEventListener("astro:page-load", initPartners);
</script>
