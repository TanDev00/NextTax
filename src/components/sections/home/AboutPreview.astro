---
import { Icon } from "astro-icon/components";
import Button from "../../ui/Button.astro";
import SectionHeading from "../../ui/SectionHeading.astro";
import type { StatItem } from "../../../types/wordpress";

interface Props {
  badge: string;
  title: string;
  image: string;
  heading: string;
  content: string;
  signature?: string;
  stats: StatItem[];
}

const { badge, title, image, heading, content, signature, stats } = Astro.props;
const safeStats = stats || [];
---

<section
  class="py-16 lg:py-32 bg-white overflow-hidden relative"
  id="about-preview-section"
>
  <!-- Decorative background elements -->
  <div class="container mx-auto px-4 max-w-7xl relative z-10">
    <div
      class="grid grid-cols-1 lg:grid-cols-[55%_45%] gap-10 lg:gap-16 items-start"
    >
      <!-- Left Column -->
      <div class="flex flex-col gap-8 md:gap-12">
        <SectionHeading
          badge={badge}
          title={title}
          badgeClass="about-label"
          titleClass="about-heading text-2xl md:text-3xl lg:text-4xl"
        />

        <div class="about-image relative mt-8 group">
          <!-- Decorative Border Frame -->
          <div
            class="absolute inset-0 translate-x-4 translate-y-4 -z-10 group-hover:translate-x-2 group-hover:translate-y-2 transition-transform duration-700"
          >
          </div>

          <a
            href="/about"
            class="relative w-full block overflow-hidden rounded-xl border border-slate-100 transition-all duration-500 bg-white"
          >
            <!-- Background arrow vectors (Decorative) -->
            <div
              class="absolute -right-20 top-1/2 -translate-y-1/2 w-48 h-48 opacity-5 -z-10 text-slate-900 group-hover:rotate-12 transition-transform duration-1000"
            >
              <Icon name="lucide:arrow-up" class="w-full h-full" />
            </div>
            <!-- Cutout Square Effect (Top Left) -->
            <img
              src={image}
              alt={title}
              class="w-full h-auto object-cover transition-all duration-1000 group-hover:scale-110"
              width="800"
              height="1000"
              loading="lazy"
              decoding="async"
            />
          </a>
        </div>

        <!-- Relocated Stats List (Now in a white card for better contrast) -->
        <div
          class="w-full px-6 md:px-8 mt-2 overflow-hidden relative"
          id="stats-container"
        >
          <!-- Subtle decor for stats card -->
          <div class="absolute -right-4 -bottom-4 w-24 h-24"></div>

          {
            safeStats.map((stat, index) => (
              <div
                class={`stat-row flex flex-col sm:flex-row sm:items-center py-6 gap-4 sm:gap-12 transition-colors hover:bg-slate-50 ${index !== safeStats.length - 1 ? "border-b border-slate-50" : ""}`}
              >
                <div class="text-3xl md:text-4xl font-extrabold text-slate-900 sm:w-32 flex items-center">
                  <span class="counter-value" data-target={stat.value}>
                    0
                  </span>
                  <span>{stat.suffix}</span>
                </div>
                <div class="text-slate-700 font-bold text-sm md:text-base flex-1">
                  {stat.label}
                </div>
              </div>
            ))
          }
        </div>
      </div>
      <!-- Right Column -->
      <div class="flex flex-col gap-10 lg:pt-12 relative">
        <div class="about-text-block space-y-8 py-8 md:py-12 relative z-10">
          <h3 class="text-2xl font-bold text-slate-900 leading-tight">
            {heading}
          </h3>
          <div
            class="space-y-4 leading-relaxed text-[18px] text-slate-600"
            set:html={content}
          />

          <!-- Signature area -->
          {
            signature && (
              <div class="about-signature pt-4 border-t border-slate-50">
                <div class="w-48 opacity-80 mix-blend-multiply">
                  <img
                    src={signature}
                    alt="Signature"
                    class="w-full h-auto object-contain"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              </div>
            )
          }
        </div>

        <div class="about-cta-btn pt-2 pl-4">
          <Button
            variant="primary"
            size="lg"
            className="bg-[#f36a33] hover:bg-[#e05b26] text-white rounded-md font-bold uppercase text-sm tracking-widest px-10 border-none"
            href="/about"
          >
            Xem thêm về chúng tôi <Icon
              name="lucide:arrow-up-right"
              class="w-4 h-4 ml-2 inline-block"
            />
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import {
    fadeIn,
    staggerReveal,
    clipPathReveal,
  } from "../../animations/fadeIn";

  const initAboutPreviewAnim = () => {
    fadeIn(".about-label", 0, -30);
    fadeIn(".about-heading", 0.2);
    clipPathReveal(".about-image", 0.4);
    fadeIn(".about-text-block", 0.5);
    fadeIn(".about-signature", 0.6, 20);
    staggerReveal(".stat-row", 0.12, 0.7);
    fadeIn(".about-cta-btn", 0.8);

    // --- Number Counter Animation (Keep custom logic as it's specialized) ---
    const container = document.getElementById("stats-container");
    if (!container) return;

    const counters = container.querySelectorAll(".counter-value");
    let hasAnimated = false;

    const startCounting = () => {
      counters.forEach((counter) => {
        const targetElement = counter as HTMLElement;
        const target = parseFloat(
          targetElement.getAttribute("data-target") || "0",
        );
        const duration = 2000;
        const stepTime = Math.abs(Math.floor(duration / 60));
        let current = 0;
        const increment = target / (duration / stepTime);

        const timer = setInterval(() => {
          current += increment;
          if (current >= target) {
            targetElement.innerText = target.toLocaleString("en-US");
            clearInterval(timer);
          } else {
            targetElement.innerText =
              Math.ceil(current).toLocaleString("en-US");
          }
        }, stepTime);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting && !hasAnimated) {
          hasAnimated = true;
          startCounting();
          observer.disconnect();
        }
      },
      { threshold: 0.1 },
    );

    observer.observe(container);
  };

  initAboutPreviewAnim();
  document.addEventListener("astro:page-load", initAboutPreviewAnim);
</script>
