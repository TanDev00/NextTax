---
import { Icon } from 'astro-icon/components';

const logos = [
  { name: 'TECHBRAND', class: 'font-black tracking-tighter' },
  { name: 'SMATRICS', class: 'font-black tracking-widest uppercase' },
  { name: 'Bayern', class: 'font-serif italic font-bold' },
  { name: 'acrevis', class: 'font-bold tracking-tight lowercase' },
  { name: 'SAUTER', class: 'font-extrabold uppercase' },
  { name: 'EVOLVED', class: 'font-black italic uppercase' },
];
---

<section class="py-10 md:py-16 bg-white border-t border-slate-100" id="partners-section">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="swiper partner-logo-swiper">
      <div class="swiper-wrapper items-center">
        {logos.map(logo => (
          <div class="swiper-slide !w-auto pr-16 md:pr-24">
            <div class={`partner-logo text-2xl md:text-3xl text-slate-300 hover:text-slate-900 transition-colors duration-500 cursor-pointer ${logo.class}`}>
              <div class="flex items-center gap-2">
                {logo.name === 'TECHBRAND' && <Icon name="lucide:layers" class="w-7 h-7" />}
                {logo.name}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Autoplay } from 'swiper/modules';
  import 'swiper/css';
  import { fadeIn } from '../animations/fadeIn';

  const initPartners = () => {
    // Entrance animation
    fadeIn('.partner-logo-swiper', 0.2, 30);

    // Continuous loop Swiper
    new Swiper('.partner-logo-swiper', {
      modules: [Autoplay],
      slidesPerView: 'auto',
      loop: true,
      speed: 5000,
      autoplay: {
        delay: 0,
        disableOnInteraction: false,
      },
      allowTouchMove: false, 
    });
  };

  initPartners();
  document.addEventListener('astro:page-load', initPartners);
</script>
