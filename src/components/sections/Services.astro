---
import { Icon } from 'astro-icon/components';

const services = [
  {
    title: 'Kế toán trọn gói',
    description: 'Xử lý toàn bộ sổ sách, chứng từ và báo cáo tài chính hàng tháng/quý cho doanh nghiệp, đảm bảo chuẩn xác và kịp thời theo quy định pháp luật.',
    iconName: 'lucide:file-text',
    tags: ['Báo cáo thường kỳ', 'Chứng từ thuế', 'Sổ sách kế toán'],
  },
  {
    title: 'Quyết toán thuế',
    description: 'Đại diện doanh nghiệp làm việc trực tiếp với cơ quan thuế, thực hiện rà soát chuyên sâu nhằm tối ưu hóa số thuế phải nộp một cách hợp pháp.',
    iconName: 'lucide:trending-up',
    tags: ['Hoàn thuế', 'Kiểm tra', 'Bảo vệ số liệu'],
  },
  {
    title: 'Tư vấn doanh nghiệp',
    description: 'Hỗ trợ lên kế hoạch chiến lược, tối ưu mô hình tài chính và thực hiện nhanh chóng các thủ tục pháp lý, thay đổi giấy phép đầu tư.',
    iconName: 'lucide:book-open',
    tags: ['Thành lập mới', 'Chiến lược tài chính', 'Mua bán M&A'],
  },
];
---

<section class="py-16 lg:py-32 bg-white" id="services-section">
  <div class="container mx-auto px-4 max-w-7xl">
    
    <!-- Title matching screenshot -->
    <div class="max-w-4xl mb-20 space-y-4">
      <p class="services-label text-orange-600 font-bold tracking-wide uppercase text-sm">
        Tận tâm với doanh nghiệp, hướng tới kết quả vượt trội.
      </p>
      <h2 class="services-heading text-2xl md:text-3xl lg:text-4xl font-black text-slate-900 leading-[1.15] tracking-tight">
        Chiến lược tư vấn hiệu quả, tập trung giải quyết chính xác các vấn đề cốt lõi của doanh nghiệp.
      </h2>
    </div>

    <!-- Cards Layout -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
      {services.map((service, index) => (
        <div class="service-card relative group rounded-3xl h-full p-[2px] overflow-hidden bg-white shadow-[0_4px_24px_rgb(0,0,0,0.06)] hover:shadow-2xl transition-shadow duration-500 isolate" data-index={index}>
          
          <!-- Animated Border on Hover (Hiệu ứng vòng sáng chạy quanh card) -->
          <div class="absolute inset-[-100%] opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-0 pointer-events-none">
            <div class="absolute inset-0 bg-[conic-gradient(from_0deg_at_50%_50%,transparent_0%,transparent_60%,#ef4444_80%,#fb923c_100%)] animate-spin" style="animation-duration: 3s;"></div>
          </div>

          <!-- Card Content (Mặt trước che lại spinning background, chỉ chừa 2px viền) -->
          <div class="relative w-full h-full bg-white rounded-[calc(1.5rem-2px)] z-10 p-10 flex flex-col gap-6 overflow-hidden">
            
            <!-- Soft Gradient Background (Giống ảnh gốc, màu cam đỏ nhạt bên trái) -->
            <div class="absolute inset-0 bg-gradient-to-r from-orange-500/20 via-orange-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-700 -z-10 translate-x-[-10%] group-hover:translate-x-0"></div>

            <!-- Icon -->
            <div class="text-slate-800 transition-transform duration-500 group-hover:-translate-y-1">
              <Icon name={service.iconName} class="w-12 h-12" stroke-width="1.25" />
            </div>

            <!-- Header & Description -->
            <div class="space-y-4">
              <h3 class="text-2xl font-bold text-slate-900 tracking-tight">
                {service.title}
              </h3>
              <p class="text-slate-500 leading-relaxed min-h-[100px]">
                {service.description}
              </p>
            </div>

            <!-- Tags OR Arrow on hover (Bottom Section) -->
            <div class="mt-auto pt-6 border-t border-transparent group-hover:border-transparent transition-colors">
              <div class="flex items-center justify-between min-h-[40px]">
                
                <!-- Tags (Dạng viền mảnh giống screenshot, ẩn khi hover) -->
                <div class="flex flex-wrap gap-2 group-hover:opacity-0 group-hover:-translate-y-2 transition-all duration-300 absolute w-full">
                  {service.tags.map(tag => (
                    <span class="px-3 py-1 text-xs font-medium text-slate-500 border border-slate-200 rounded-md bg-white">
                      {tag}
                    </span>
                  ))}
                </div>

                <!-- Mũi tên cam bay lên (Hiện khi hover, giống screenshot) -->
                <div class="text-orange-500 opacity-0 transform translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 delay-100 relative w-full flex">
                  <Icon name="lucide:arrow-up-right" class="w-8 h-8" />
                </div>

              </div>
            </div>

          </div>
        </div>
      ))}
    </div>
    
  </div>
</section>

<script>
  import { fadeIn, staggerReveal } from '../animations/fadeIn';

  const initServicesAnim = () => {
    fadeIn('.services-label', 0, -30);
    fadeIn('.services-heading', 0.2);
    staggerReveal('.service-card', 0.15);
  };

  initServicesAnim();
  document.addEventListener('astro:page-load', initServicesAnim);
</script>
