---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  subtitle: string;
  image?: string;
}

const { 
  title = "Gia nhập đội ngũ NextTax", 
  subtitle = "Cùng chúng tôi kiến tạo tương lai dịch vụ kế toán & thuế tại Việt Nam",
  image = "https://images.unsplash.com/photo-1521737711867-e3b97375f902?q=80&w=1974&auto=format&fit=crop"
} = Astro.props;
---

<section class="relative w-full pt-48 pb-32 md:pt-60 md:pb-44 bg-slate-900 overflow-hidden">
  <!-- Background with Overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src={image} 
      alt={title} 
      class="w-full h-full object-cover opacity-30 scale-105"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-slate-900/90 via-slate-900/60 to-slate-900"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="">
      <nav class="flex mb-12 text-white/50 text-[13px] font-bold tracking-[0.1em] uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Trang chủ</a>
        <span class="mx-3 text-white/20">/</span>
        <span class="text-white">Tuyển dụng</span>
      </nav>
      
      <h1 class="text-4xl md:text-4xl lg:text-4xl font-black text-white mb-10 leading-[1.1] tracking-tight">
        {title}
      </h1>
      <p class="text-lg md:text-lg text-white/70 leading-relaxed max-w-2xl font-medium italic">
        {subtitle}
      </p>
    </div>
  </div>
</section>
