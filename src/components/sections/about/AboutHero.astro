---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { 
  title = "Về Chúng Tôi", 
  description = "Xây dựng NextTax với sứ mệnh giúp các doanh nghiệp Việt Nam vượt qua rào cản về thủ tục pháp lý và tài chính phức tạp.",
  image = "https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&q=80&w=2000"
} = Astro.props;

import { Icon } from "astro-icon/components";
---

<section
  class="relative w-full h-[60vh] min-h-[500px] flex items-center justify-center overflow-hidden"
  id="about-page-hero"
>
  <div class="absolute inset-0">
    <img
      src={image}
      alt="About Us Header"
      class="w-full h-full object-cover"
    />
    <div
      class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/70 to-orange-900/50 mix-blend-multiply"
    >
    </div>
    <div class="absolute inset-0 bg-black/30"></div>
  </div>

  <div class="relative z-10 text-center px-4 mt-20 max-w-3xl mx-auto">
    <h1
      class="about-page-title text-5xl md:text-7xl font-bold text-white mb-6 tracking-tight"
    >
      {title}
    </h1>
    <p
      class="about-page-desc text-lg md:text-xl text-white/90 max-w-2xl mx-auto mb-8 font-medium"
    >
      {description}
    </p>
    <div
      class="flex items-center justify-center gap-3 text-white/90 text-sm md:text-base font-medium"
    >
      <a href="/" class="hover:text-white transition-colors">Trang chủ</a>
      <Icon name="lucide:chevron-right" class="w-4 h-4 opacity-70" />
      <span class="font-bold text-white">Về chúng tôi</span>
    </div>
  </div>
</section>

<script>
  import { fadeIn } from "../../animations/fadeIn";

  const initHeroAnim = () => {
    fadeIn(".about-page-title", 0);
    fadeIn(".about-page-desc", 0.2);
  };

  initHeroAnim();
  document.addEventListener("astro:page-load", initHeroAnim);
</script>
