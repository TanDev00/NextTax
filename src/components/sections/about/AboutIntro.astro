---
interface Props {
  data?: {
    title: string;
    sub_title: string;
    description: string;
    button: {
      button_title: string;
      button_link: string;
    };
    image: {
      node: {
        sourceUrl: string;
      };
    };
  };
}

const { data } = Astro.props;

import { Icon } from "astro-icon/components";
import Button from "../../ui/Button.astro";
import DecorativeImage from "../../ui/DecorativeImage.astro";
import SectionHeading from "../../ui/SectionHeading.astro";
---

<section class="py-24 bg-white relative overflow-hidden" id="about-intro">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Left Column -->
      <div class="about-page-text space-y-8 pr-0 lg:pr-10">
        <SectionHeading
          badge={data?.sub_title}
          title={data?.title || ""}
          class="mb-10"
          badgeClass="services-label"
          titleClass="services-heading"
        />
        <div class="text-lg text-slate-500 leading-relaxed font-medium" set:html={data?.description} />

        <div class="flex flex-wrap items-center gap-8 pt-4">
          <Button
            variant="primary"
            size="lg"
            href={data?.button?.button_link || "#"}
            className="bg-[#f36a33] hover:bg-[#e05b26] text-white px-8 py-4 font-bold border-none shadow-none"
          >
            {data?.button?.button_title || ""}
            <Icon
              name="lucide:arrow-up-right"
              class="w-4 h-4 ml-2 inline-block"
            />
          </Button>
        </div>
      </div>

      <!-- Right Column (Reusable Decorative Image) -->
      <DecorativeImage
        src={data?.image?.node?.sourceUrl || ""}
        alt={data?.title || ""}
        className="about-right-image"
        showArrow={true}
      />
    </div>
  </div>
</section>

<script>
  import { fadeIn } from "../../animations/fadeIn";

  const initIntroAnim = () => {
    fadeIn(".about-page-text", 0.4, -40); // Custom x/y offset logic
    fadeIn(".about-right-image", 0.6, 40);
  };

  initIntroAnim();
  document.addEventListener("astro:page-load", initIntroAnim);
</script>
