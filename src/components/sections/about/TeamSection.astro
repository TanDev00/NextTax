---
import { fade } from "astro:transitions";
import type { AboutPageData } from "../../../types/wordpress";
import SectionHeading from "../../ui/SectionHeading.astro";
import TeamCard from "./TeamCard.astro";

interface Props {
  data?: {
    title: string;
    sub_title: string;
    description: string;
    teamList: Array<{
      name: string;
      position: string;
      image: {
        node: {
          sourceUrl: string;
        };
      };
      facebook: string;
      twitter: string;
      youtube: string;
    }>;
  };
}

const { data } = Astro.props;
---

<section class="py-20 bg-slate-50/50" id="team-section">
  <div class="container mx-auto px-4 max-w-7xl">
    <SectionHeading
      badge={data?.sub_title || ""}
      title={data?.title || ""}
      subtitle={data?.description || ""}
      centered
      class="mb-20"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
      {
        data?.teamList?.map((member) => (
          <TeamCard
            name={member.name}
            role={member.position}
            image={member.image?.node?.sourceUrl || ""}
            isFeatured={false}
          />
        ))
      }
    </div>
  </div>
</section>

<script>
  import { staggerReveal } from "../../animations/fadeIn";

  const initTeamAnim = () => {
    staggerReveal(".team-card", 0.15, 0.2);
  };

  initTeamAnim();
  document.addEventListener("astro:page-load", initTeamAnim);
</script>
