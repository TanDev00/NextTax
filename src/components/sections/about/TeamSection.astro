---
import SectionHeading from "../../ui/SectionHeading.astro";
import TeamCard from "./TeamCard.astro";

const teamData = [
  {
    name: "Mike Dooley",
    role: "Giám Đốc Điều Hành (CEO)",
    image: "/images/team/team-1.png",
    isFeatured: false,
  },
  {
    name: "Emma Watson",
    role: "Chuyên Gia Tư Vấn Thuế",
    image: "/images/team/team-2.png",
    isFeatured: true,
  },
  {
    name: "John David",
    role: "Cố Vấn Tài Chính Cao Cấp",
    image: "/images/team/team-3.png",
    isFeatured: false,
  },
];
---

<section class="py-24 bg-slate-50/50" id="team-section">
  <div class="container mx-auto px-4 max-w-7xl">
    <SectionHeading 
      badge="Gương mặt đại diện"
      title="Đội Ngũ Chuyên Gia <span class='text-orange-600'>Tâm Huyết</span>"
      subtitle="Chúng tôi tập hợp những chuyên gia hàng đầu để đảm bảo sự thịnh vượng bền vững cho doanh nghiệp bạn."
      centered
      class="mb-20"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
      {teamData.map((member) => (
        <TeamCard 
          name={member.name}
          role={member.role}
          image={member.image}
          isFeatured={member.isFeatured}
        />
      ))}
    </div>
  </div>
</section>

<script>
  import { staggerReveal } from "../../animations/fadeIn";

  const initTeamAnim = () => {
    staggerReveal(".team-card", 0.15, 0.2);
  };

  initTeamAnim();
  document.addEventListener("astro:page-load", initTeamAnim);
</script>
