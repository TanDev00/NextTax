---
import Button from '../ui/Button.astro';
---

<section class="relative w-full py-16 md:py-24 flex items-center justify-center overflow-hidden" id="cta-section">
  <!-- Full-width background image -->
  <div class="absolute inset-0 z-0">
    <img 
      src="https://images.unsplash.com/photo-1554224154-26032ffc0d07?auto=format&fit=crop&q=70&w=1200" 
      alt="Calculator and Accounting Background" 
      class="cta-bg w-full h-full object-cover object-center grayscale-[30%]"
      width="1200"
      height="800"
      loading="lazy"
      decoding="async"
    />
    <!-- Heavy Dark overlay to match screenshot mood -->
    <div class="absolute inset-0 bg-slate-900/85"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 text-center flex flex-col items-center">
    
    <div class="max-w-3xl space-y-6">
      <h2 class="cta-heading text-white text-2xl md:text-4xl lg:text-5xl font-black tracking-tight leading-tight">
        Giải Pháp Thuế Chuẩn Xác, Dành Riêng Cho Bạn.
      </h2>
      
      <p class="cta-desc text-white/90 text-[17px] md:text-xl font-medium leading-relaxed">
        NextTax có thể giúp gì cho doanh nghiệp của bạn? Cùng trao đổi với chuyên gia qua số <strong class="text-white">0123 456 789</strong> để bắt đầu.
      </p>
    </div>

    <!-- Button keeps the exact requested variant styling from Button component -->
    <div class="cta-button pt-10">
      <Button variant="primary" size="lg" className="px-12 py-4">
        XEM CÁC DỊCH VỤ
      </Button>
    </div>
    
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { fadeIn } from '../animations/fadeIn';

  const initCTAAnim = () => {
    const section = document.getElementById('cta-section');
    if (!section) return;

    // Parallax background (specialized logic)
    gsap.fromTo('.cta-bg',
      { scale: 1.15 },
      {
        scale: 1, ease: 'none',
        scrollTrigger: {
          trigger: section,
          start: 'top bottom',
          end: 'bottom top',
          scrub: true
        }
      }
    );

    // Reusable animations
    fadeIn('.cta-heading', 0, 40); // Custom y offset
    fadeIn('.cta-desc', 0.2);
    fadeIn('.cta-button', 0.4, 30);
  };

  initCTAAnim();
  document.addEventListener('astro:page-load', initCTAAnim);
</script>
