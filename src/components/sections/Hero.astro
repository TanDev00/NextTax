---
import { Icon } from 'astro-icon/components';

const slides = [
  {
    title: 'Grow Your Wealth With Our Leading Edge Solutions!',
    subtitle: 'Take control of your financial future and start growing your wealth',
    image: 'https://images.unsplash.com/photo-1600880292203-757bb62b4baf?auto=format&fit=crop&q=80&w=2000',
  },
  {
    title: 'Tối ưu hóa thuế & Quản trị rủi ro chuyên nghiệp',
    subtitle: 'Đội ngũ chuyên gia hàng đầu mang đến giải pháp bảo vệ tài chính an toàn nhất',
    image: 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?auto=format&fit=crop&q=80&w=2000',
  },
  {
    title: 'Giải pháp kế toán toàn diện cho doanh nghiệp',
    subtitle: 'Giúp bạn tối đa hóa lợi nhuận và tập trung nguồn lực phát triển kinh doanh',
    image: 'https://images.unsplash.com/photo-1542744173-8e7e53415bb0?auto=format&fit=crop&q=80&w=2000',
  }
];
---

<section class="relative w-full h-screen min-h-[600px] bg-slate-900 group" id="hero-section">
  <div class="swiper hero-swiper w-full h-full">
    <div class="swiper-wrapper">
      {slides.map((slide, index) => (
        <div class="swiper-slide relative w-full h-full">
          <!-- Background Image with Gradient Overlay -->
          <div class="absolute inset-0">
            <img src={slide.image} alt={slide.title} class="w-full h-full object-cover hero-bg-img" />
            <div class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/60 to-transparent"></div>
          </div>
          
          <!-- Content -->
          <div class="relative container mx-auto px-6 h-full flex items-center">
            <div class="max-w-3xl space-y-6 pt-20">
              <p class="hero-subtitle text-white/80 font-semibold tracking-wider uppercase text-sm md:text-base">
                {slide.subtitle}
              </p>
              <h1 class="hero-title text-3xl md:text-5xl lg:text-6xl font-black text-white leading-[1.1] tracking-tight">
                {slide.title}
              </h1>
              
              <div class="pt-8 flex items-center gap-6 hero-cta">
                <!-- Round arrow button style similar to screenshot -->
                <a href="/services" class="w-20 h-20 rounded-full border border-white/50 flex items-center justify-center text-white hover:bg-white hover:text-slate-900 transition-colors group/btn">
                  <Icon name="lucide:arrow-up-right" class="w-8 h-8 group-hover/btn:translate-x-1 group-hover/btn:-translate-y-1 transition-transform" />
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Swiper Navigation Bottom Controls -->
    <div class="absolute bottom-10 left-0 w-full z-10">
      <div class="container mx-auto px-6">
        <div class="hero-bottom-bar flex items-center gap-12 border-t border-white/20 pt-6">
          <div class="flex-1">
            <h3 class="text-white font-bold text-lg mb-2">We help our clients achieve their goals</h3>
            <p class="text-white/60 text-sm">Providing expert consulting services</p>
          </div>
          <div class="flex gap-4">
            <button class="swiper-button-prev-custom w-12 h-12 rounded-full flex items-center justify-center text-white hover:bg-white/10 transition-colors">
              <Icon name="lucide:chevron-left" class="w-6 h-6" />
            </button>
            <button class="swiper-button-next-custom w-12 h-12 rounded-full flex items-center justify-center text-white hover:bg-white/10 transition-colors">
              <Icon name="lucide:chevron-right" class="w-6 h-6" />
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Navigation, Autoplay, EffectFade } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/effect-fade';
  import { gsap } from 'gsap';
  import { fadeIn } from '../animations/fadeIn';

  const initHero = () => {
    // --- GSAP Hero entrance animation ---
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    // Initial states (hidden)
    gsap.set('.hero-subtitle', { opacity: 0, y: 40 });
    gsap.set('.hero-title', { opacity: 0, y: 60, clipPath: 'inset(0 0 100% 0)' });
    gsap.set('.hero-cta', { opacity: 0, y: 30, scale: 0.8 });
    gsap.set('.hero-bottom-bar', { opacity: 0, y: 30 });

    tl.to('.hero-subtitle', { opacity: 1, y: 0, duration: 0.8, delay: 0.3 })
      .to('.hero-title', { opacity: 1, y: 0, clipPath: 'inset(0 0 0% 0)', duration: 1.2 }, '-=0.5')
      .to('.hero-cta', { opacity: 1, y: 0, scale: 1, duration: 0.8 }, '-=0.6')
      .to('.hero-bottom-bar', { opacity: 1, y: 0, duration: 0.8 }, '-=0.5');

    // Subtle parallax on hero background
    const heroSection = document.getElementById('hero-section');
    if (heroSection) {
      window.addEventListener('scroll', () => {
        const scrollY = window.scrollY;
        const heroHeight = heroSection.offsetHeight;
        if (scrollY < heroHeight) {
          const imgs = heroSection.querySelectorAll('.hero-bg-img') as NodeListOf<HTMLElement>;
          imgs.forEach(img => {
            img.style.transform = `translateY(${scrollY * 0.3}px) scale(1.1)`;
          });
        }
      });
    }

    // --- Swiper ---
    new Swiper('.hero-swiper', {
      modules: [Navigation, Autoplay, EffectFade],
      effect: 'fade',
      fadeEffect: { crossFade: true },
      speed: 1000,
      autoplay: {
        delay: 6000,
        disableOnInteraction: false,
      },
      navigation: {
        nextEl: '.swiper-button-next-custom',
        prevEl: '.swiper-button-prev-custom',
      },
      loop: true,
      on: {
        slideChangeTransitionStart: () => {
          // Animate text in on slide change
          gsap.fromTo('.swiper-slide-active .hero-subtitle', 
            { opacity: 0, y: 30 }, 
            { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out', delay: 0.2 }
          );
          gsap.fromTo('.swiper-slide-active .hero-title', 
            { opacity: 0, y: 50, clipPath: 'inset(0 0 100% 0)' }, 
            { opacity: 1, y: 0, clipPath: 'inset(0 0 0% 0)', duration: 1, ease: 'power2.out', delay: 0.3 }
          );
          gsap.fromTo('.swiper-slide-active .hero-cta', 
            { opacity: 0, scale: 0.8 }, 
            { opacity: 1, scale: 1, duration: 0.7, ease: 'back.out(1.4)', delay: 0.6 }
          );
        }
      }
    });
  };

  initHero();
  document.addEventListener('astro:page-load', initHero);
</script>

<style>
  .hero-bg-img {
    transform: scale(1.1);
    will-change: transform;
  }
</style>
