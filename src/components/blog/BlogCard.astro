---
import Card from '../ui/Card.astro';
import Badge from '../ui/Badge.astro';
import { formatDate } from '../../lib/format';

interface Props {
  post: {
    title: string;
    slug: string;
    excerpt: string;
    date: string;
    category: string;
    image: string;
  };
}

const { post } = Astro.props;
---

<Card className="flex flex-col h-full">
  <div class="h-48 overflow-hidden">
    <img 
      src={post.image} 
      alt={post.title} 
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
    />
  </div>
  <div class="p-6 flex flex-col flex-1 gap-4">
    <div class="flex justify-between items-center text-xs font-bold text-slate-400 uppercase tracking-widest">
      <Badge variant="neutral">{post.category}</Badge>
      <span>{formatDate(post.date)}</span>
    </div>
    <h3 class="text-xl leading-tight group-hover:text-indigo-600 transition-colors">
      <a href={`/blog/${post.slug}`}>{post.title}</a>
    </h3>
    <p class="text-slate-600 text-sm line-clamp-3">
      {post.excerpt}
    </p>
    <a href={`/blog/${post.slug}`} class="mt-auto text-sm font-bold text-indigo-600 hover:underline">
      Đọc thêm &rarr;
    </a>
  </div>
</Card>
