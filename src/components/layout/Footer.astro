---
import { Icon } from 'astro-icon/components';

const currentYear = new Date().getFullYear();

const company = [
  { label: 'Giới thiệu', href: '/about' },
  { label: 'Tầm nhìn & Sứ mệnh', href: '/about' },
  { label: 'Đội ngũ chuyên gia', href: '/about' },
  { label: 'Tin tức & Blog', href: '/blog' },
  { label: 'Tuyển dụng', href: '/careers' },
];

const services = [
  { label: 'Kế toán trọn gói', href: '/services' },
  { label: 'Quyết toán thuế', href: '/services' },
  { label: 'Tư vấn doanh nghiệp', href: '/services' },
  { label: 'Thay đổi giấy phép', href: '/services' },
  { label: 'Kiểm toán nội bộ', href: '/services' },
  { label: 'Quản lý rủi ro', href: '/services' },
];

const industries = [
  { label: 'Ngân hàng & Tài chính', href: '#' },
  { label: 'Công nghệ & Phần mềm', href: '#' },
  { label: 'Sản xuất & Thương mại', href: '#' },
  { label: 'Giáo dục & Đào tạo', href: '#' },
  { label: 'Y tế & Dược phẩm', href: '#' },
  { label: 'Bất động sản', href: '#' },
];
---

<footer class="bg-slate-950 text-slate-400" id="site-footer">
  
  <!-- Top Links Section -->
  <div class="container mx-auto px-4 max-w-7xl pt-20 pb-16">
    <div class="footer-columns grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr_1fr] gap-12 lg:gap-8">
      
      <!-- Newsletter / CTA Text -->
      <div class="footer-col space-y-6 pr-6">
        <p class="text-white/90 text-[15px] leading-relaxed font-medium">
          Đăng ký nhận bản tin, cập nhật chính sách thuế mới nhất, góc nhìn chiến lược và nội dung chuyên sâu từ NextTax.
        </p>
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 border border-white/30 text-white text-xs font-bold uppercase tracking-widest hover:bg-white hover:text-slate-900 transition-all duration-300">
          Đăng ký
          <Icon name="lucide:arrow-up-right" class="w-3.5 h-3.5" />
        </a>
      </div>

      <!-- Company -->
      <div class="footer-col">
        <h4 class="text-white font-bold text-sm uppercase tracking-wider mb-6">Công ty</h4>
        <ul class="space-y-3 text-sm">
          {company.map(link => (
            <li><a href={link.href} class="hover:text-white transition-colors duration-200">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div class="footer-col">
        <h4 class="text-white font-bold text-sm uppercase tracking-wider mb-6">Dịch vụ</h4>
        <ul class="space-y-3 text-sm">
          {services.map(link => (
            <li><a href={link.href} class="hover:text-white transition-colors duration-200">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Industries -->
      <div class="footer-col">
        <h4 class="text-white font-bold text-sm uppercase tracking-wider mb-6">Ngành nghề</h4>
        <ul class="space-y-3 text-sm">
          {industries.map(link => (
            <li><a href={link.href} class="hover:text-white transition-colors duration-200">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Quick Contacts -->
      <div class="footer-col">
        <h4 class="text-white font-bold text-sm uppercase tracking-wider mb-6">Liên hệ nhanh</h4>
        <ul class="space-y-4 text-sm">
          <li>
            <a href="mailto:contact@nexttax.vn" class="flex items-center gap-2 hover:text-white transition-colors">
              <Icon name="lucide:mail" class="w-4 h-4" /> contact@nexttax.vn
            </a>
          </li>
          <li>
            <a href="tel:0123456789" class="flex items-center gap-2 hover:text-white transition-colors">
              <Icon name="lucide:phone" class="w-4 h-4" /> 0123 456 789
            </a>
          </li>
          <li class="flex items-start gap-2">
            <Icon name="lucide:map-pin" class="w-4 h-4 mt-0.5" />
            <span>123 Đường Đông Du, Q.1, Hồ Chí Minh</span>
          </li>
        </ul>
        <div class="flex items-center gap-4 mt-6">
          <a href="#" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-rose-500 transition-colors" aria-label="Facebook">
            <Icon name="lucide:facebook" class="w-4 h-4" />
          </a>
          <a href="#" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-rose-500 transition-colors" aria-label="Twitter">
            <Icon name="lucide:twitter" class="w-4 h-4" />
          </a>
          <a href="#" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-rose-500 transition-colors" aria-label="YouTube">
            <Icon name="lucide:youtube" class="w-4 h-4" />
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- "Get In Touch" Large Banner -->
  <div class="border-t border-white/10">
    <div class="container mx-auto px-4 max-w-7xl py-12 flex flex-col md:flex-row items-center justify-between gap-8">
      <a href="/contact" class="group">
        <h2 class="footer-big-text text-4xl md:text-5xl lg:text-6xl font-black text-white italic tracking-tight hover:text-rose-500 transition-colors duration-300">
          Liên Hệ Ngay
        </h2>
      </a>
      <a href="/contact" class="footer-big-arrow w-20 h-20 border border-white/30 flex items-center justify-center text-white hover:bg-rose-500 hover:border-rose-500 transition-all duration-300 shrink-0">
        <Icon name="lucide:arrow-up-right" class="w-9 h-9" />
      </a>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="container mx-auto px-4 max-w-7xl py-6 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-slate-500">
      <p>&copy; {currentYear} NextTax - Kế Toán & Thuế Hồ Chí Minh. Co-working with ❤️ by NextTax Team.</p>
      <div class="flex items-center gap-6">
        <a href="/terms" class="hover:text-white transition-colors">Điều khoản</a>
        <span class="text-white/20">–</span>
        <a href="/privacy" class="hover:text-white transition-colors">Chính sách bảo mật</a>
        <span class="text-white/20">–</span>
        <a href="/sitemap" class="hover:text-white transition-colors">Site Map</a>
      </div>
    </div>
  </div>
  
</footer>

<script>
  import { gsap } from 'gsap';
  import { fadeIn, staggerReveal } from '../animations/fadeIn';

  const initFooterAnim = () => {
    staggerReveal('.footer-col', 0.1);
    fadeIn('.footer-big-text', 0.3, -80);
    
    // Specialized arrow animation
    gsap.fromTo('.footer-big-arrow',
      { opacity: 0, rotate: -90, scale: 0.5 },
      {
        opacity: 1, rotate: 0, scale: 1, duration: 0.8, ease: 'back.out(2)',
        scrollTrigger: { trigger: '.footer-big-arrow', start: 'top 90%', toggleActions: 'play none none none' }
      }
    );
  };

  initFooterAnim();
  document.addEventListener('astro:page-load', initFooterAnim);
</script>
