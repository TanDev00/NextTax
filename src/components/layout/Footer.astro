---
const currentYear = new Date().getFullYear();

const company = [
  { label: 'Giới thiệu', href: '/about' },
  { label: 'Tầm nhìn & Sứ mệnh', href: '/about' },
  { label: 'Đội ngũ chuyên gia', href: '/about' },
  { label: 'Tin tức & Blog', href: '/blog' },
  { label: 'Tuyển dụng', href: '/careers' },
];

const services = [
  { label: 'Kế toán trọn gói', href: '/services' },
  { label: 'Quyết toán thuế', href: '/services' },
  { label: 'Tư vấn doanh nghiệp', href: '/services' },
  { label: 'Thay đổi giấy phép', href: '/services' },
  { label: 'Kiểm toán nội bộ', href: '/services' },
  { label: 'Quản lý rủi ro', href: '/services' },
];

const industries = [
  { label: 'Ngân hàng & Tài chính', href: '#' },
  { label: 'Công nghệ & Phần mềm', href: '#' },
  { label: 'Sản xuất & Thương mại', href: '#' },
  { label: 'Giáo dục & Đào tạo', href: '#' },
  { label: 'Y tế & Dược phẩm', href: '#' },
  { label: 'Bất động sản', href: '#' },
];
---

<footer class="bg-slate-950 text-slate-400">
  
  <!-- Top Links Section -->
  <div class="container mx-auto px-4 max-w-7xl pt-20 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr_1fr] gap-12 lg:gap-8">
      
      <!-- Newsletter / CTA Text -->
      <div class="space-y-6 pr-6">
        <p class="text-white/90 text-[15px] leading-relaxed font-medium">
          Đăng ký nhận bản tin, cập nhật chính sách thuế mới nhất, góc nhìn chiến lược và nội dung chuyên sâu từ NextTax.
        </p>
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 border border-white/30 text-white text-xs font-bold uppercase tracking-widest hover:bg-white hover:text-slate-900 transition-all duration-300">
          Đăng ký
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-white font-bold text-sm uppercase tracking-wider mb-6">Công ty</h4>
        <ul class="space-y-3 text-sm">
          {company.map(link => (
            <li><a href={link.href} class="hover:text-white transition-colors duration-200">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-white font-bold text-sm uppercase tracking-wider mb-6">Dịch vụ</h4>
        <ul class="space-y-3 text-sm">
          {services.map(link => (
            <li><a href={link.href} class="hover:text-white transition-colors duration-200">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Industries -->
      <div>
        <h4 class="text-white font-bold text-sm uppercase tracking-wider mb-6">Ngành nghề</h4>
        <ul class="space-y-3 text-sm">
          {industries.map(link => (
            <li><a href={link.href} class="hover:text-white transition-colors duration-200">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Quick Contacts -->
      <div>
        <h4 class="text-white font-bold text-sm uppercase tracking-wider mb-6">Liên hệ nhanh</h4>
        <ul class="space-y-3 text-sm">
          <li><a href="mailto:info@nexttax.vn" class="hover:text-white transition-colors">info@nexttax.vn</a></li>
          <li><a href="tel:+84123456789" class="hover:text-white transition-colors">+84 123 456 789</a></li>
        </ul>
        <div class="flex items-center gap-4 mt-6">
          <a href="#" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-rose-500 transition-colors" aria-label="Facebook">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-rose-500 transition-colors" aria-label="Twitter">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-rose-500 transition-colors" aria-label="YouTube">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- "Get In Touch" Large Banner -->
  <div class="border-t border-white/10">
    <div class="container mx-auto px-4 max-w-7xl py-12 flex flex-col md:flex-row items-center justify-between gap-8">
      <a href="/contact" class="group">
        <h2 class="text-5xl md:text-7xl lg:text-8xl font-black text-white italic tracking-tight hover:text-rose-500 transition-colors duration-300">
          Liên Hệ Ngay
        </h2>
      </a>
      <a href="/contact" class="w-20 h-20 border border-white/30 flex items-center justify-center text-white hover:bg-rose-500 hover:border-rose-500 transition-all duration-300 shrink-0">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
      </a>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="container mx-auto px-4 max-w-7xl py-6 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-slate-500">
      <p>&copy; {currentYear} NextTax, All Rights Reserved. With ❤️ by NextTax Team.</p>
      <div class="flex items-center gap-6">
        <a href="/terms" class="hover:text-white transition-colors">Điều khoản</a>
        <span class="text-white/20">–</span>
        <a href="/privacy" class="hover:text-white transition-colors">Chính sách bảo mật</a>
        <span class="text-white/20">–</span>
        <a href="/sitemap" class="hover:text-white transition-colors">Site Map</a>
      </div>
    </div>
  </div>
  
</footer>
