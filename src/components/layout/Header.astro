---
import { Icon } from 'astro-icon/components';
import Button from '../ui/Button.astro';
import SearchModal from '../ui/SearchModal.astro';
import { getHeaderData } from '../../services/wordpress';

const headerData = await getHeaderData();

// Fallback sử dụng cấu trúc NavItem mới: url là object { url, title, target }
const navItems = headerData?.navItems?.length ? headerData.navItems : [
  { label: 'Trang chủ', url: { url: '/', title: '', target: '' }, subitem: [] },
  { label: 'Dịch vụ',   url: { url: '/services', title: '', target: '' }, subitem: [] },
  { label: 'Về chúng tôi', url: { url: '/about', title: '', target: '' }, subitem: [] },
  { label: 'Tin tức',   url: { url: '/blog', title: '', target: '' }, subitem: [] },
  { label: 'Liên hệ',  url: { url: '/contact', title: '', target: '' }, subitem: [] },
];

const logoText    = headerData?.logoText    || 'NextTax';
const logoIconText = headerData?.logoIconText || 'N';
const ctaButton   = headerData?.ctaButton   || { label: 'Tư vấn ngay', url: '/contact' };

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '';

// Format WP URL sang relative URL của Astro
const formatUrl = (url: any) => {
  if (!url) return '#';
  // Nếu url vẫn là một object (do GraphQL backend chưa update) thì tách lấy url string
  let urlStr = url;
  if (typeof url === 'object' && url.url) {
    urlStr = url.url;
  }
  if (typeof urlStr !== 'string') return '#';

  try {
    const formattedUrl = new URL(urlStr);
    // Nếu URL dẫn tới backend WordPress, ta trả về relative path
    if (formattedUrl.hostname.includes('backend.nexttax.vn') || formattedUrl.hostname.includes('nexttax.vn')) {
      return formattedUrl.pathname.toLowerCase();
    }
  } catch (e) {
    // Không parse được (đã là relative path vd: /about)
  }
  return urlStr.toLowerCase();
};

const isActive = (url: string | null | undefined) => {
  const formattedUrl = formatUrl(url);
  if (!formattedUrl || formattedUrl === '#') return false;
  if (formattedUrl === '/') return currentPath === '/';
  const normalizedPath = currentPath.replace(/\/$/, '');
  const normalizedUrlStr  = formattedUrl.replace(/\/$/, '');
  return normalizedPath === normalizedUrlStr || currentPath.startsWith(formattedUrl + '/');
};
---

<header id="main-header" class={`fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b ${isHome ? 'bg-transparent text-white border-white/20' : 'bg-white/90 backdrop-blur-md border-slate-100 text-slate-800 shadow-sm'}`} data-ishome={isHome ? 'true' : 'false'}>
  <div class="container mx-auto px-4 h-24 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <div class="w-10 h-10 bg-orange-600 rounded-md flex items-center justify-center group-hover:rotate-6 transition-transform logo-icon">
        <span class="text-white font-black text-xl leading-none">{logoIconText}</span>
      </div>
      <span class="text-2xl font-black tracking-tight" id="header-logo-text">{logoText.includes('Tax') ? <>{logoText.replace('Tax', '')}<span class="text-orange-600 border-none px-0">Tax</span></> : logoText}</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navItems.map(item => {
        const href       = formatUrl(item.url);
        const hasSubmenu = item.subitem && item.subitem.length > 0;
        return (
          <div class="relative group h-full py-4">
            <a
              href={href}
              target="_self"
              class={`font-bold transition-all flex items-center gap-1 ${isActive(href) ? 'text-[#f36a33]' : 'hover:text-[#f36a33] group-hover:text-[#f36a33] opacity-90 hover:opacity-100'}`}
            >
              {item.label}
              {hasSubmenu && <Icon name="lucide:chevron-down" class="w-4 h-4 transition-transform group-hover:rotate-180" />}
            </a>

            {hasSubmenu && (
              <div class="absolute top-full left-0 min-w-[220px] bg-white rounded-xl shadow-xl border border-slate-100 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all duration-200 py-2 z-50 border-t-2 border-t-[#f36a33] translate-y-2 group-hover:translate-y-0">
                {item.subitem!.map(sub => (
                  <a
                    href={formatUrl(sub.url?.url)}
                    target={sub.url?.target || '_self'}
                    class="block px-4 py-2.5 text-sm font-semibold text-slate-700 hover:text-[#f36a33] hover:bg-orange-50 transition-colors"
                  >
                    {sub.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        );
      })}
    </nav>

    <div class="flex items-center gap-4">
      <div class="hidden md:block">
        <button id="search-btn" class="w-10 h-10 flex items-center justify-center hover:opacity-70 transition-opacity" aria-label="Search">
          <Icon name="lucide:search" class="w-5 h-5" />
        </button>
      </div>
      <div class="hidden lg:block">
        <Button variant="primary" size="sm" href={formatUrl(ctaButton.url)} className="get-quote-btn shadow-none">
          {ctaButton.label} <Icon name="lucide:arrow-up-right" class="w-4 h-4 ml-1 inline-block" />
        </Button>
      </div>

      <!-- Mobile menu toggle -->
      <button id="mobile-menu-toggle" class="md:hidden w-10 h-10 flex items-center justify-center relative z-[60]" aria-label="Toggle Menu">
        <Icon name="lucide:menu" class="w-6 h-6 menu-icon-open" />
        <Icon name="lucide:x" class="w-6 h-6 menu-icon-close hidden" />
      </button>
    </div>
  </div>

  <!-- Mobile Slide-Down Menu -->
  <div id="mobile-menu" class="md:hidden overflow-hidden max-h-0 transition-all duration-500 ease-in-out bg-white border-t border-slate-100 shadow-xl">
    <nav class="container mx-auto px-4 py-6 flex flex-col gap-1">
      {navItems.map((item, idx) => {
        const href       = formatUrl(item.url);
        const hasSubmenu = item.subitem && item.subitem.length > 0;
        return (
          <div>
            <a
              href={hasSubmenu ? '#' : href}
              target="_self"
              data-accordion-toggle={hasSubmenu ? `submenu-${idx}` : undefined}
              class={`mobile-nav-link flex items-center justify-between px-4 py-3.5 font-bold text-base rounded-md transition-colors ${isActive(href) ? 'text-[#f36a33] bg-orange-50/50' : 'text-slate-800 hover:bg-slate-50 hover:text-[#f36a33]'}`}
            >
              {item.label}
              {hasSubmenu && <Icon name="lucide:chevron-down" class={`w-4 h-4 transition-transform accordion-icon-${idx}`} />}
            </a>

            {hasSubmenu && (
              <div id={`submenu-${idx}`} class="overflow-hidden max-h-0 transition-all duration-300 pl-4">
                {item.subitem!.map(sub => (
                  <a
                    href={formatUrl(sub.url?.url)}
                    target={sub.url?.target || '_self'}
                    class="mobile-nav-link block px-4 py-2.5 text-sm font-semibold  hover:text-[#f36a33] hover:bg-orange-50/50 rounded-md transition-colors"
                  >
                    {sub.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        );
      })}

      <div class="mt-4 px-4 flex flex-col gap-3">
        <button id="mobile-search-btn" class="flex items-center gap-3 px-4 py-3.5 font-bold text-slate-800 hover:bg-slate-50 rounded-md transition-colors">
          <Icon name="lucide:search" class="w-5 h-5" /> Tìm kiếm
        </button>
        <Button variant="primary" size="md" href={formatUrl(ctaButton.url)} className="w-full justify-center shadow-none">
          {ctaButton.label} <Icon name="lucide:arrow-up-right" class="w-4 h-4 ml-1 inline-block" />
        </Button>
      </div>
    </nav>
  </div>
</header>

<SearchModal />

{!isHome && <div class="h-24"></div>}

<script>
  const initHeader = () => {
    const header    = document.getElementById('main-header');
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const searchBtn  = document.getElementById('search-btn');
    const mobileSearchBtn = document.getElementById('mobile-search-btn');

    if (!header || !toggleBtn || !mobileMenu) return;

    // Search Toggle
    const toggleSearch = () => window.dispatchEvent(new CustomEvent('toggle-search'));
    searchBtn?.addEventListener('click', toggleSearch);
    mobileSearchBtn?.addEventListener('click', () => {
      const isMenuOpen = mobileMenu.style.maxHeight !== '0px';
      if (isMenuOpen) toggleBtn.click();
      setTimeout(toggleSearch, 300);
    });

    // Mobile accordion for subitems
    mobileMenu.querySelectorAll('[data-accordion-toggle]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = (btn as HTMLElement).dataset.accordionToggle!;
        const submenu  = document.getElementById(targetId);
        if (!submenu) return;
        const isOpen = submenu.style.maxHeight && submenu.style.maxHeight !== '0px';
        
        // Close all submenus
        mobileMenu.querySelectorAll('[data-accordion-toggle]').forEach(b => {
          const sid = (b as HTMLElement).dataset.accordionToggle!;
          const sm  = document.getElementById(sid);
          if (sm) sm.style.maxHeight = '0px';
        });

        // Toggle current
        if (!isOpen) {
          submenu.style.maxHeight = submenu.scrollHeight + 'px';
          // Ensure parent wrapper can fit the new expanded content
          mobileMenu.style.maxHeight = (mobileMenu.scrollHeight + submenu.scrollHeight) + 'px';
        } else {
          // Keep parent menu open but re-adjust its internal height safely
          mobileMenu.style.maxHeight = mobileMenu.scrollHeight + 'px';
        }
      });
    });

    const isHome = header.dataset.ishome === 'true';
    let isMenuOpen = false;

    const iconOpen  = toggleBtn.querySelector('.menu-icon-open')  as HTMLElement;
    const iconClose = toggleBtn.querySelector('.menu-icon-close') as HTMLElement;

    const openMenu = () => {
      isMenuOpen = true;
      mobileMenu.style.maxHeight = '2000px'; // Bỏ giới hạn để accordion tự do đẩy
      header.classList.remove('bg-transparent', 'text-white', 'border-white/20');
      header.classList.add('bg-white', 'backdrop-blur-md', 'border-slate-100', 'text-slate-800', 'shadow-sm');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
    };

    const closeMenu = () => {
      isMenuOpen = false;
      mobileMenu.style.maxHeight = '0px';
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      header.classList.remove('bg-white', 'bg-white/95', 'backdrop-blur-md', 'border-slate-100', 'text-slate-800', 'shadow-sm', 'bg-transparent', 'text-white', 'border-white/20');
      if (isHome) {
        handleScroll();
      } else {
        header.classList.add('bg-white/90', 'backdrop-blur-md', 'border-slate-100', 'text-slate-800', 'shadow-sm');
      }
    };

    toggleBtn.addEventListener('click', () => isMenuOpen ? closeMenu() : openMenu());

    // Close menu on regular link click (not accordion toggles)
    mobileMenu.querySelectorAll('a:not([data-accordion-toggle])').forEach(link => {
      link.addEventListener('click', () => closeMenu());
    });

    const handleScroll = () => {
      if (isMenuOpen) return;
      if (window.scrollY > 50) {
        header.classList.remove('bg-transparent', 'text-white', 'border-white/20');
        header.classList.add('bg-white/95', 'backdrop-blur-md', 'border-slate-100', 'text-slate-800', 'shadow-sm');
      } else {
        header.classList.add('bg-transparent', 'text-white', 'border-white/20');
        header.classList.remove('bg-white/95', 'backdrop-blur-md', 'border-slate-100', 'text-slate-800', 'shadow-sm');
      }
    };

    if (isHome) {
      handleScroll();
      window.addEventListener('scroll', handleScroll);
    }
  };

  initHeader();
  document.addEventListener('astro:page-load', initHeader);
</script>
