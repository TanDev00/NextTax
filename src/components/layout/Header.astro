---
import { Icon } from 'astro-icon/components';
import Button from '../ui/Button.astro';

const navItems = [
  { label: 'Trang chủ', href: '/' },
  { label: 'Dịch vụ', href: '/services' },
  { label: 'Về chúng tôi', href: '/about' },
  { label: 'Tin tức', href: '/blog' },
  { label: 'Liên hệ', href: '/contact' },
];

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '';

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  // Check exact match or starts with path + trailing slash for nested routes (like /blog/slug)
  return currentPath.replace(/\/$/, '') === href.replace(/\/$/, '') || currentPath.startsWith(href + '/');
};
---

<header id="main-header" class={`fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b ${isHome ? 'bg-transparent text-white border-white/20' : 'bg-white/90 backdrop-blur-md border-slate-100 text-slate-800 shadow-sm'}`} data-ishome={isHome ? 'true' : 'false'}>
  <div class="container mx-auto px-4 h-24 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <div class="w-10 h-10 bg-orange-600 rounded-xl flex items-center justify-center group-hover:rotate-6 transition-transform logo-icon">
        <span class="text-white font-black text-xl leading-none">N</span>
      </div>
      <span class="text-2xl font-black tracking-tight" id="header-logo-text">Next<span class="text-orange-600 border-none px-0">Tax</span></span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class={`font-bold transition-all ${isActive(item.href) ? 'text-[#f36a33]' : 'hover:text-[#f36a33]'}`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-4">
      <div class="hidden md:block">
        <button class="w-10 h-10 flex items-center justify-center hover:opacity-70 transition-opacity">
          <Icon name="lucide:search" class="w-5 h-5" />
        </button>
      </div>
      <div class="hidden lg:block">
        <Button variant="primary" size="sm" className="get-quote-btn shadow-none">
          Tư vấn ngay <Icon name="lucide:arrow-up-right" class="w-4 h-4 ml-1 inline-block" />
        </Button>
      </div>

      <!-- Mobile menu toggle -->
      <button id="mobile-menu-toggle" class="md:hidden w-10 h-10 flex items-center justify-center relative z-[60]" aria-label="Toggle Menu">
        <Icon name="lucide:menu" class="w-6 h-6 menu-icon-open" />
        <Icon name="lucide:x" class="w-6 h-6 menu-icon-close hidden" />
      </button>
    </div>
  </div>

  <!-- Mobile Slide-Down Menu -->
  <div id="mobile-menu" class="md:hidden overflow-hidden max-h-0 transition-all duration-500 ease-in-out bg-white border-t border-slate-100 shadow-xl">
    <nav class="container mx-auto px-4 py-6 flex flex-col gap-1">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class={`mobile-nav-link block px-4 py-3.5 font-bold text-base rounded-xl transition-colors ${isActive(item.href) ? 'text-[#f36a33] bg-orange-50/50' : 'text-slate-800 hover:bg-slate-50 hover:text-[#f36a33]'}`}
        >
          {item.label}
        </a>
      ))}
      <div class="mt-4 px-4">
        <Button variant="primary" size="md" className="w-full justify-center shadow-none">
          Tư vấn ngay <Icon name="lucide:arrow-up-right" class="w-4 h-4 ml-1 inline-block" />
        </Button>
      </div>
    </nav>
  </div>
</header>

{!isHome && <div class="h-24"></div>}

<script>
  const initHeader = () => {
    const header = document.getElementById('main-header');
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    if (!header || !toggleBtn || !mobileMenu) return;

    const isHome = header.dataset.ishome === 'true';
    let isMenuOpen = false;

    const iconOpen = toggleBtn.querySelector('.menu-icon-open') as HTMLElement;
    const iconClose = toggleBtn.querySelector('.menu-icon-close') as HTMLElement;

    const openMenu = () => {
      isMenuOpen = true;
      mobileMenu.style.maxHeight = mobileMenu.scrollHeight + 'px';

      // Force white background when menu is open
      header.classList.remove('bg-transparent', 'text-white', 'border-white/20');
      header.classList.add('bg-white', 'backdrop-blur-md', 'border-slate-100', 'text-slate-800', 'shadow-sm');

      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
    };

    const closeMenu = () => {
      isMenuOpen = false;
      mobileMenu.style.maxHeight = '0px';

      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');

      // Remove all header style classes first (including bg-white from openMenu)
      header.classList.remove('bg-white', 'bg-white/95', 'backdrop-blur-md', 'border-slate-100', 'text-slate-800', 'shadow-sm', 'bg-transparent', 'text-white', 'border-white/20');

      // Restore header style based on scroll position
      if (isHome) {
        handleScroll();
      } else {
        // Non-home pages: always white bg
        header.classList.add('bg-white/90', 'backdrop-blur-md', 'border-slate-100', 'text-slate-800', 'shadow-sm');
      }
    };

    toggleBtn.addEventListener('click', () => {
      if (isMenuOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    // Close menu when clicking a nav link
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => closeMenu());
    });

    // Scroll handler for homepage
    const handleScroll = () => {
      if (isMenuOpen) return; // Don't change styles while menu is open

      if (window.scrollY > 50) {
        header.classList.remove('bg-transparent', 'text-white', 'border-white/20');
        header.classList.add('bg-white/95', 'backdrop-blur-md', 'border-slate-100', 'text-slate-800', 'shadow-sm');
      } else {
        header.classList.add('bg-transparent', 'text-white', 'border-white/20');
        header.classList.remove('bg-white/95', 'backdrop-blur-md', 'border-slate-100', 'text-slate-800', 'shadow-sm');
      }
    };

    if (isHome) {
      handleScroll();
      window.addEventListener('scroll', handleScroll);
    }
  };

  initHeader();
  document.addEventListener('astro:page-load', initHeader);
</script>
