---
export const prerender = true;
import MainLayout from "../layouts/MainLayout.astro";
import ContactHero from "../components/sections/contact/ContactHero.astro";
import ContactInfo from "../components/sections/contact/ContactInfo.astro";
import ContactForm from "../components/sections/contact/ContactForm.astro";
import ContactMap from "../components/sections/contact/ContactMap.astro";
import FAQ from "../components/sections/shared/FAQ.astro";
---

<MainLayout title="Liên hệ - NextTax">
  <ContactHero />

  <section class="section-padding">
    <div class="container mx-auto px-4 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-[35%_65%] gap-20 items-start">
        <ContactInfo />
        <ContactForm />
      </div>
    </div>
  </section>
  <FAQ />

  <ContactMap />
</MainLayout>
