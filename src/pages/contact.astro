---
import MainLayout from '../layouts/MainLayout.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
---

<MainLayout title="Liên hệ - NextTax">
  <section class="pt-32 pb-20 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-6xl mb-6">Liên hệ với <span class="text-indigo-600">chúng tôi</span></h1>
        <p class="text-xl text-slate-600">
          Đội ngũ của chúng tôi luôn sẵn sàng lắng nghe và giải đáp mọi thắc mắc của bạn 24/7.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div class="space-y-12">
          <div class="space-y-6">
            <h2 class="text-3xl">Thông tin liên hệ</h2>
            <div class="space-y-4">
              <a href="#" class="flex items-center gap-4 text-lg text-slate-600 hover:text-indigo-600 transition-colors">
                <div class="w-12 h-12 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-600">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.28-2.28a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                0123 456 789
              </a>
              <a href="#" class="flex items-center gap-4 text-lg text-slate-600 hover:text-indigo-600 transition-colors">
                <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </div>
                contact@nexttax.vn
              </a>
              <div class="flex items-center gap-4 text-lg text-slate-600">
                <div class="w-12 h-12 rounded-xl bg-amber-50 flex items-center justify-center text-amber-600">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                Hồ Chí Minh, Việt Nam
              </div>
            </div>
          </div>
          
          <div class="p-8 rounded-[2rem] bg-slate-900 text-white space-y-4">
            <h3 class="text-xl">Giờ làm việc</h3>
            <div class="space-y-2 text-slate-400">
              <div class="flex justify-between">
                <span>Thứ 2 - Thứ 6</span>
                <span class="text-white">08:00 - 17:30</span>
              </div>
              <div class="flex justify-between">
                <span>Thứ 7</span>
                <span class="text-white">08:00 - 12:00</span>
              </div>
              <div class="flex justify-between">
                <span>Chủ nhật</span>
                <span class="text-rose-400">Nghỉ</span>
              </div>
            </div>
          </div>
        </div>

        <Card className="p-8 md:p-12 border-none shadow-2xl shadow-indigo-100">
          <form class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="text-sm font-bold text-slate-700">Họ và tên</label>
                <input type="text" placeholder="Nguyễn Văn A" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-indigo-600 focus:ring-4 focus:ring-indigo-50 outline-none transition-all" />
              </div>
              <div class="space-y-2">
                <label class="text-sm font-bold text-slate-700">Số điện thoại</label>
                <input type="tel" placeholder="0901 234 567" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-indigo-600 focus:ring-4 focus:ring-indigo-50 outline-none transition-all" />
              </div>
            </div>
            <div class="space-y-2">
              <label class="text-sm font-bold text-slate-700">Email</label>
              <input type="email" placeholder="example@gmail.com" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-indigo-600 focus:ring-4 focus:ring-indigo-50 outline-none transition-all" />
            </div>
            <div class="space-y-2">
              <label class="text-sm font-bold text-slate-700">Dịch vụ quan tâm</label>
              <select class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-indigo-600 focus:ring-4 focus:ring-indigo-50 outline-none transition-all appearance-none cursor-pointer">
                <option>Kế toán trọn gói</option>
                <option>Quyết toán thuế</option>
                <option>Thành lập doanh nghiệp</option>
                <option>Khác</option>
              </select>
            </div>
            <div class="space-y-2">
              <label class="text-sm font-bold text-slate-700">Tin nhắn</label>
              <textarea rows="4" placeholder="Tôi cần tư vấn về..." class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-indigo-600 focus:ring-4 focus:ring-indigo-50 outline-none transition-all resize-none"></textarea>
            </div>
            <Button variant="primary" size="lg" className="w-full">Gửi yêu cầu</Button>
          </form>
        </Card>
      </div>
    </div>
  </section>
</MainLayout>
