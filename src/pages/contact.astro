---
export const prerender = true;
import { Icon } from 'astro-icon/components';
import MainLayout from '../layouts/MainLayout.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
---

<MainLayout title="Liên hệ - NextTax">
  <section class="relative w-full h-[60vh] min-h-[500px] flex items-center justify-center" id="contact-hero">
    <div class="absolute inset-0">
      <img 
        src="https://images.unsplash.com/photo-1516387938699-a93567ec168e?auto=format&fit=crop&q=80&w=2000" 
        alt="Contact Header" 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/70 to-orange-900/50 mix-blend-multiply"></div>
      <div class="absolute inset-0 bg-black/30"></div>
    </div>

    <div class="relative z-10 text-center px-4 mt-20 max-w-3xl mx-auto">
      <h1 class="contact-title text-5xl md:text-7xl font-bold text-white mb-6 tracking-tight">Liên Hệ</h1>
      <p class="contact-desc text-lg md:text-xl text-white/90 max-w-2xl mx-auto mb-8 font-medium">
        Đội ngũ chuyên gia kế toán của chúng tôi tại Hồ Chí Minh luôn sẵn sàng lắng nghe và giải đáp mọi thắc mắc của bạn.
      </p>
      <div class="flex items-center justify-center gap-3 text-white/90 text-sm md:text-base font-medium">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <Icon name="lucide:chevron-right" class="w-4 h-4 opacity-70" />
        <span class="font-bold text-white">Liên hệ</span>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div class="contact-info space-y-12">
          <div class="space-y-6">
            <h2 class="text-3xl font-bold">Văn phòng Hồ Chí Minh</h2>
            <div class="space-y-4">
              <a href="tel:0123456789" class="contact-item flex items-center gap-4 text-lg text-slate-600 hover:text-indigo-600 transition-colors">
                <div class="w-12 h-12 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-600">
                  <Icon name="lucide:phone" class="w-6 h-6" />
                </div>
                0123 456 789
              </a>
              <a href="mailto:contact@nexttax.vn" class="contact-item flex items-center gap-4 text-lg text-slate-600 hover:text-indigo-600 transition-colors">
                <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600">
                  <Icon name="lucide:mail" class="w-6 h-6" />
                </div>
                contact@nexttax.vn
              </a>
              <div class="contact-item flex items-center gap-4 text-lg text-slate-600">
                <div class="w-12 h-12 rounded-xl bg-amber-50 flex items-center justify-center text-amber-600">
                  <Icon name="lucide:map-pin" class="w-6 h-6" />
                </div>
                123 Đường Đông Du, Q.1, Hồ Chí Minh
              </div>
            </div>
          </div>
          
          <div class="contact-hours p-8 rounded-[2rem] bg-slate-900 text-white space-y-4">
            <h3 class="text-xl">Giờ làm việc</h3>
            <div class="space-y-2 text-slate-400">
              <div class="flex justify-between">
                <span>Thứ 2 - Thứ 6</span>
                <span class="text-white">08:00 - 17:30</span>
              </div>
              <div class="flex justify-between">
                <span>Thứ 7</span>
                <span class="text-white">08:00 - 12:00</span>
              </div>
              <div class="flex justify-between">
                <span>Chủ nhật</span>
                <span class="text-rose-400">Nghỉ</span>
              </div>
            </div>
          </div>
        </div>

        <Card className="contact-form-card p-8 md:p-12 border-none shadow-2xl shadow-indigo-100">
          <form class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="text-sm font-bold text-slate-700">Họ và tên</label>
                <input type="text" placeholder="Nguyễn Văn A" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-indigo-600 focus:ring-4 focus:ring-indigo-50 outline-none transition-all" />
              </div>
              <div class="space-y-2">
                <label class="text-sm font-bold text-slate-700">Số điện thoại</label>
                <input type="tel" placeholder="0901 234 567" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-indigo-600 focus:ring-4 focus:ring-indigo-50 outline-none transition-all" />
              </div>
            </div>
            <div class="space-y-2">
              <label class="text-sm font-bold text-slate-700">Email</label>
              <input type="email" placeholder="example@gmail.com" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-indigo-600 focus:ring-4 focus:ring-indigo-50 outline-none transition-all" />
            </div>
            <div class="space-y-2">
              <label class="text-sm font-bold text-slate-700">Dịch vụ quan tâm</label>
              <select class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-indigo-600 focus:ring-4 focus:ring-indigo-50 outline-none transition-all appearance-none cursor-pointer">
                <option>Kế toán trọn gói</option>
                <option>Quyết toán thuế</option>
                <option>Thành lập doanh nghiệp</option>
                <option>Khác</option>
              </select>
            </div>
            <div class="space-y-2">
              <label class="text-sm font-bold text-slate-700">Tin nhắn</label>
              <textarea rows="4" placeholder="Tôi cần tư vấn về..." class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-indigo-600 focus:ring-4 focus:ring-indigo-50 outline-none transition-all resize-none"></textarea>
            </div>
            <Button variant="primary" size="lg" className="w-full">
              <Icon name="lucide:send" class="w-4 h-4 mr-2 inline-block" /> Gửi yêu cầu
            </Button>
          </form>
        </Card>
      </div>
    </div>
  <section class="pb-24">
    <div class="container mx-auto px-4">
      <div class="w-full h-[450px] rounded-[2.5rem] overflow-hidden shadow-2xl shadow-slate-200/50 contact-map">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m12!1m3!1d3919.4582352822!2d106.701!3d10.776!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752f4700000001%3A0x1234567890abcdef!2zMTIzIMSQxrDhu51uZyDEkMO0bmcgRHUsIFBoxhu51uZyBC4bq_biBOZ2jDqSwgUXXhuq1uIDEsIEjhu5MgQ2jDrSBNaW5oLCBWaeG7h3QgTmFt!5e0!3m2!1svi!2s!4v1700000000000!5m2!1svi!2s" 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
          class="grayscale opacity-80 hover:grayscale-0 hover:opacity-100 transition-all duration-700"
        ></iframe>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  import { fadeIn, staggerReveal } from '../components/animations/fadeIn';

  const initContactAnim = () => {
    fadeIn('.contact-title', 0);
    fadeIn('.contact-desc', 0.2);
    staggerReveal('.contact-item', 0.12, 0.4);
    fadeIn('.contact-hours', 0.6);
    fadeIn('.contact-form-card', 0.8, 50);
    fadeIn('.contact-map', 1, 30);
  };

  initContactAnim();
  document.addEventListener('astro:page-load', initContactAnim);
</script>
