---
export const prerender = true;
import { Icon } from 'astro-icon/components';
import MainLayout from '../../layouts/MainLayout.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';

const services = [
  {
    title: 'Kế toán trọn gói',
    slug: 'ke-toan-tron-goi',
    description: 'Xử lý toàn bộ sổ sách, chứng từ và báo cáo tài chính hàng tháng/quý cho doanh nghiệp.',
    iconName: 'lucide:bar-chart-3',
    price: 'Từ 1.000.000đ/tháng'
  },
  {
    title: 'Quyết toán thuế',
    slug: 'quyet-toan-thue',
    description: 'Đại diện doanh nghiệp làm việc với cơ quan thuế, tối ưu số thuế phải nộp đúng luật.',
    iconName: 'lucide:landmark',
    price: 'Liên hệ tư vấn'
  },
  {
    title: 'Thành lập doanh nghiệp',
    slug: 'thanh-lap-doanh-nghiep',
    description: 'Hỗ trợ thủ tục pháp lý từ A-Z để doanh nghiệp bắt đầu hoạt động nhanh chóng.',
    iconName: 'lucide:rocket',
    price: 'Chỉ từ 2.000.000đ'
  },
  {
    title: 'Thay đổi giấy phép',
    slug: 'thay-doi-giay-phep',
    description: 'Cập nhật thông tin đăng ký kinh doanh, người đại diện, vốn điều lệ...',
    iconName: 'lucide:clipboard-list',
    price: 'Liên hệ tư vấn'
  },
  {
    title: 'Giải thể doanh nghiệp',
    slug: 'giai-the-doanh-nghiep',
    description: 'Thủ tục đóng mã số thuế và giải thể doanh nghiệp đúng quy định pháp luật.',
    iconName: 'lucide:building-2',
    price: 'Liên hệ tư vấn'
  },
  {
    title: 'Chữ ký số & Hóa đơn',
    slug: 'chu-ky-so-hoa-don',
    description: 'Cung cấp và hỗ trợ cài đặt chữ ký số, hóa đơn điện tử chính hãng.',
    iconName: 'lucide:pen-tool',
    price: 'Giá đại lý'
  }
];
---

<MainLayout title="Dịch vụ - NextTax">
  <section class="relative w-full h-[60vh] min-h-[500px] flex items-center justify-center" id="services-page-hero">
    <div class="absolute inset-0">
      <img 
        src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&q=80&w=2000" 
        alt="Services Header" 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/70 to-orange-900/50 mix-blend-multiply"></div>
      <div class="absolute inset-0 bg-black/30"></div>
    </div>

    <div class="relative z-10 text-center px-4 mt-20 max-w-3xl mx-auto">
      <h1 class="page-hero-title text-5xl md:text-7xl font-bold text-white mb-6 tracking-tight">Dịch Vụ</h1>
      <p class="page-hero-desc text-lg md:text-xl text-white/90 max-w-3xl mx-auto mb-8 font-medium">
        Giải pháp pháp lý và tài chính trọn gói giúp doanh nghiệp tối ưu vận hành và tuân thủ pháp luật một cách dễ dàng.
      </p>
      <div class="flex items-center justify-center gap-3 text-white/90 text-sm md:text-base font-medium">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <Icon name="lucide:chevron-right" class="w-4 h-4 opacity-70" />
        <span class="font-bold text-white">Dịch vụ</span>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map(service => (
          <Card className="svc-page-card p-8 flex flex-col items-start gap-6">
            <div class="w-16 h-16 rounded-2xl bg-indigo-50 flex items-center justify-center text-indigo-600">
              <Icon name={service.iconName} class="w-8 h-8" />
            </div>
            <div class="space-y-4">
              <h3 class="text-2xl">{service.title}</h3>
              <p class="text-slate-600 leading-relaxed">
                {service.description}
              </p>
              <div class="text-indigo-600 font-bold">
                {service.price}
              </div>
            </div>
            <Button variant="outline" className="w-full mt-4" href={`/services/${service.slug}`}>
              Xem chi tiết <Icon name="lucide:arrow-right" class="w-4 h-4 ml-1 inline-block" />
            </Button>
          </Card>
        ))}
      </div>
    </div>
  </section>
</MainLayout>

<script>
  import { fadeIn, staggerReveal } from '../../components/animations/fadeIn';

  const initServicesPageAnim = () => {
    fadeIn('.page-hero-title', 0);
    fadeIn('.page-hero-desc', 0.2);
    staggerReveal('.svc-page-card', 0.1, 0.4);
  };

  initServicesPageAnim();
  document.addEventListener('astro:page-load', initServicesPageAnim);
</script>
