---
export const prerender = true;
import MainLayout from "../../layouts/MainLayout.astro";
import WhyChooseUs from "../../components/sections/service/WhyChooseUs.astro";
import ServiceHero from "../../components/sections/service/ServiceHero.astro";
import ServiceList from "../../components/sections/service/ServiceList.astro";
import WorkFlow from "../../components/sections/service/WorkFlow.astro";

import { getServicePageData } from "../../services/wordpress";

const data = await getServicePageData();

const services =
  data?.service?.listService?.map((s: any) => ({
    title: s.title,
    slug: typeof s.slug === "object" ? s.slug?.url : s?.slug,
    description: s.description,
    iconName: "lucide:pen-tool",
    priceValue: s.priceValue,
    features: s.features?.map((f: any) => f.feature) || [],
  })) || [];
---

<MainLayout title={data?.heroBanner?.title || "Dịch vụ - NextTax"}>
  <ServiceHero
    title={data?.heroBanner?.title}
    description={data?.heroBanner?.subtitle}
    image={data?.heroBanner?.imageBanner?.node?.sourceUrl}
  />
  <ServiceList
    services={services}
    title={data?.service?.title}
    badge={data?.service?.description}
  />
  <WhyChooseUs data={data?.whyChooseUs} />
  <WorkFlow data={data?.workFlow} />
</MainLayout>
