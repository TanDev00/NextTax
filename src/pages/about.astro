---
export const prerender = true;
import MainLayout from "../layouts/MainLayout.astro";
import CompanyIdentity from "../components/sections/service/CompanyIdentity.astro";
import AboutHero from "../components/sections/about/AboutHero.astro";
import AboutIntro from "../components/sections/about/AboutIntro.astro";
import AboutStats from "../components/sections/about/AboutStats.astro";
import TeamSection from "../components/sections/about/TeamSection.astro";

import { getAboutPageData } from "../services/wordpress";
import WhyChooseUs from "../components/sections/service/WhyChooseUs.astro";
const data = await getAboutPageData();
---

<MainLayout title={data?.heroBanner?.title}>
  <AboutHero
    title={data?.heroBanner?.title}
    description={data?.heroBanner?.description}
    image={data?.heroBanner?.imageBanner?.node?.sourceUrl}
  />
  <AboutIntro data={data?.introduction} />
  <CompanyIdentity data={data?.core_values} />
  <WhyChooseUs data={data?.whyChooseUs} />
  <TeamSection data={data?.team} />
  <AboutStats data={data?.numbers} />
</MainLayout>
