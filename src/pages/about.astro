---
export const prerender = true;
import { Icon } from 'astro-icon/components';
import MainLayout from '../layouts/MainLayout.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
---

<MainLayout title="Về chúng tôi - NextTax">
  <section class="relative w-full h-[60vh] min-h-[500px] flex items-center justify-center overflow-hidden" id="about-page-hero">
    <div class="absolute inset-0">
      <img 
        src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&q=80&w=2000" 
        alt="About Us Header" 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/70 to-orange-900/50 mix-blend-multiply"></div>
      <div class="absolute inset-0 bg-black/30"></div>
    </div>

    <div class="relative z-10 text-center px-4 mt-20 max-w-3xl mx-auto">
      <h1 class="about-page-title text-5xl md:text-7xl font-bold text-white mb-6 tracking-tight">Về Chúng Tôi</h1>
      <p class="about-page-desc text-lg md:text-xl text-white/90 max-w-2xl mx-auto mb-8 font-medium">
        Xây dựng NextTax với sứ mệnh giúp các doanh nghiệp Việt Nam vượt qua rào cản về thủ tục pháp lý và tài chính phức tạp.
      </p>
      <div class="flex items-center justify-center gap-3 text-white/90 text-sm md:text-base font-medium">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <Icon name="lucide:chevron-right" class="w-4 h-4 opacity-70" />
        <span class="font-bold text-white">Về chúng tôi</span>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div class="about-page-text space-y-6">
          <h2 class="text-3xl">Tầm nhìn & Sứ mệnh</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            NextTax hướng tới việc trở thành người bạn đồng hành tin cậy nhất của doanh nghiệp SME tại Việt Nam, nơi công nghệ và tri thức kết hợp để mang lại giá trị thực sự.
          </p>
          <p class="text-lg text-slate-600 leading-relaxed">
            Chúng tôi tin rằng khi doanh nghiệp không còn phải lo lắng về sổ sách, họ sẽ có nhiều thời gian và nguồn lực hơn để sáng tạo và bứt phá.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <Card className="about-stat-card p-6 text-center shadow-none bg-indigo-50 border-none">
            <div class="text-4xl font-bold text-indigo-600 mb-2">500+</div>
            <div class="text-xs font-bold text-slate-500 uppercase">Khách hàng</div>
          </Card>
          <Card className="about-stat-card p-6 text-center shadow-none bg-emerald-50 border-none">
            <div class="text-4xl font-bold text-emerald-600 mb-2">10+</div>
            <div class="text-xs font-bold text-slate-500 uppercase">Năm kinh nghiệm</div>
          </Card>
          <Card className="about-stat-card p-6 text-center shadow-none bg-amber-50 border-none">
            <div class="text-4xl font-bold text-amber-600 mb-2">15+</div>
            <div class="text-xs font-bold text-slate-500 uppercase">Chuyên gia</div>
          </Card>
          <Card className="about-stat-card p-6 text-center shadow-none bg-rose-50 border-none">
            <div class="text-4xl font-bold text-rose-600 mb-2">99%</div>
            <div class="text-xs font-bold text-slate-500 uppercase">Hài lòng</div>
          </Card>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  import { fadeIn, staggerReveal } from '../components/animations/fadeIn';

  const initAboutPageAnim = () => {
    fadeIn('.about-page-title', 0);
    fadeIn('.about-page-desc', 0.2);
    fadeIn('.about-page-text', 0.4, -40); // Custom x/y offset logic
    staggerReveal('.about-stat-card', 0.1, 0.6);
  };

  initAboutPageAnim();
  document.addEventListener('astro:page-load', initAboutPageAnim);
</script>
