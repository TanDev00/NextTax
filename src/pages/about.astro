---
export const prerender = true;
import { Icon } from "astro-icon/components";
import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
---

<MainLayout title="Về chúng tôi - NextTax">
  <section
    class="relative w-full h-[60vh] min-h-[500px] flex items-center justify-center overflow-hidden"
    id="about-page-hero"
  >
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&q=80&w=2000"
        alt="About Us Header"
        class="w-full h-full object-cover"
      />
      <div
        class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/70 to-orange-900/50 mix-blend-multiply"
      >
      </div>
      <div class="absolute inset-0 bg-black/30"></div>
    </div>

    <div class="relative z-10 text-center px-4 mt-20 max-w-3xl mx-auto">
      <h1
        class="about-page-title text-5xl md:text-7xl font-bold text-white mb-6 tracking-tight"
      >
        Về Chúng Tôi
      </h1>
      <p
        class="about-page-desc text-lg md:text-xl text-white/90 max-w-2xl mx-auto mb-8 font-medium"
      >
        Xây dựng NextTax với sứ mệnh giúp các doanh nghiệp Việt Nam vượt qua rào
        cản về thủ tục pháp lý và tài chính phức tạp.
      </p>
      <div
        class="flex items-center justify-center gap-3 text-white/90 text-sm md:text-base font-medium"
      >
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <Icon name="lucide:chevron-right" class="w-4 h-4 opacity-70" />
        <span class="font-bold text-white">Về chúng tôi</span>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white relative overflow-hidden">
    <div class="container mx-auto px-4 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Left Column -->
        <div class="about-page-text space-y-8 pr-0 lg:pr-10">
          <h2
            class="text-4xl md:text-5xl lg:text-[3.5rem] font-black text-slate-900 leading-[1.1] tracking-tight"
          >
            Bứt Phá Tăng Trưởng Cùng Các Giải Pháp Tư Vấn Tiên Phong!
          </h2>
          <p class="text-lg text-slate-500 leading-relaxed font-medium">
            Chúng tôi là tổ chức tư vấn với nhiều năm kinh nghiệm thực chiến đa ngành, tự hào sát cánh cùng sự phát triển tài chính của hàng ngàn doanh nghiệp. Đội ngũ chuyên gia của chúng tôi mang đến định hướng chiến lược, khai phóng tiềm năng, tối ưu hóa lợi nhuận và đảm bảo an toàn tuyệt đối cho mọi quyết định đầu tư.
          </p>

          <div class="flex flex-wrap items-center gap-8 pt-4">
            <Button
              variant="primary"
              size="lg"
              className="rounded-none bg-[#f36a33] hover:bg-[#e05b26] text-white px-8 py-4 font-bold border-none shadow-none"
            >
              Về Chúng Tôi <Icon
                name="lucide:arrow-up-right"
                class="w-4 h-4 ml-2 inline-block"
              />
            </Button>
          </div>
        </div>

        <!-- Right Column (Image with Giant Arrow) -->
        <div
          class="about-right-image border-none bg-transparent shadow-none w-full h-[500px] lg:h-[600px] relative mt-10 lg:mt-0"
        >
          <img
            src="https://images.unsplash.com/photo-1542744173-8e7e53415bb0?auto=format&fit=crop&q=80&w=1200"
            alt="Business professionals walking"
            class="w-full h-full object-cover"
          />
          <!-- The giant thin white arrow overlay -->
          <div
            class="absolute bottom-10 right-10 w-48 h-48 md:w-64 md:h-64 text-white opacity-90 pointer-events-none"
          >
            <Icon
              name="lucide:arrow-down-right"
              class="w-full h-full stroke-[1.5] drop-shadow-md"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Number Counters Section -->
  <section class="py-20 bg-white border-t border-slate-100">
    <div class="container mx-auto px-4 max-w-7xl">
      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12"
        id="about-stats-container"
      >
        <div class="about-stat-item space-y-4">
          <div class="flex items-baseline gap-2">
            <h3
              class="text-4xl lg:text-[2.75rem] font-bold text-slate-900 tracking-tight stat-counter"
              data-target="6154"
            >
              0
            </h3>
            <Icon
              name="lucide:arrow-up-right"
              class="w-6 h-6 text-slate-900 stroke-1 opacity-80"
            />
          </div>
          <p class="text-sm text-slate-500 leading-relaxed font-medium pr-4">
            Dự án và hồ sơ chiến lược đã được công ty triển khai thành công.
          </p>
        </div>

        <div class="about-stat-item space-y-4">
          <div class="flex items-baseline gap-2">
            <h3
              class="text-4xl lg:text-[2.75rem] font-bold text-slate-900 tracking-tight stat-counter"
              data-target="2512"
            >
              0
            </h3>
            <Icon
              name="lucide:arrow-up-right"
              class="w-6 h-6 text-slate-900 stroke-1 opacity-80"
            />
          </div>
          <p class="text-sm text-slate-500 leading-relaxed font-medium pr-4">
            Chuyên gia tài chính và kế toán trình độ cao sẵn sàng hỗ trợ bạn.
          </p>
        </div>

        <div class="about-stat-item space-y-4">
          <div class="flex items-baseline gap-2">
            <h3
              class="text-4xl lg:text-[2.75rem] font-bold text-slate-900 tracking-tight stat-counter"
              data-target="1784"
            >
              0
            </h3>
            <Icon
              name="lucide:arrow-up-right"
              class="w-6 h-6 text-slate-900 stroke-1 opacity-80"
            />
          </div>
          <p class="text-sm text-slate-500 leading-relaxed font-medium pr-4">
            Khách hàng hoàn toàn hài lòng với chất lượng dịch vụ trên toàn quốc.
          </p>
        </div>

        <div class="about-stat-item space-y-4">
          <div class="flex items-baseline gap-2">
            <!-- Used prefix 0, to match exactly what is in the provided image -->
            <h3
              class="text-4xl lg:text-[2.75rem] font-bold text-slate-900 tracking-tight stat-counter"
              data-target="29"
              data-prefix="0,"
            >
              0
            </h3>
            <Icon
              name="lucide:arrow-up-right"
              class="w-6 h-6 text-slate-900 stroke-1 opacity-80"
            />
          </div>
          <p class="text-sm text-slate-500 leading-relaxed font-medium pr-4">
            Năm kinh nghiệm uy tín trong lĩnh vực hoạch định và quản lý thuế.
          </p>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  import { fadeIn, staggerReveal } from "../components/animations/fadeIn";

  const initAboutPageAnim = () => {
    fadeIn(".about-page-title", 0);
    fadeIn(".about-page-desc", 0.2);
    fadeIn(".about-page-text", 0.4, -40); // Custom x/y offset logic
    fadeIn(".about-right-image", 0.6, 40);

    // Animate stats container showing up
    staggerReveal(".about-stat-item", 0.1, 0.2);

    // Number Counter Logic
    const container = document.getElementById("about-stats-container");
    if (!container) return;

    const counters = container.querySelectorAll(".stat-counter");
    let hasAnimated = false;

    const startCounting = () => {
      counters.forEach((counter) => {
        const targetElement = counter as HTMLElement;
        const target = parseFloat(
          targetElement.getAttribute("data-target") || "0",
        );
        const prefix = targetElement.getAttribute("data-prefix") || "";
        const duration = 2000;
        const stepTime = Math.abs(Math.floor(duration / 60));
        let current = 0;
        const increment = target / (duration / stepTime);

        const timer = setInterval(() => {
          current += increment;
          if (current >= target) {
            targetElement.innerText = prefix + target.toLocaleString("en-US");
            clearInterval(timer);
          } else {
            targetElement.innerText =
              prefix + Math.ceil(current).toLocaleString("en-US");
          }
        }, stepTime);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting && !hasAnimated) {
          hasAnimated = true;
          startCounting();
          observer.disconnect();
        }
      },
      { threshold: 0.2 },
    );

    observer.observe(container);
  };

  initAboutPageAnim();
  document.addEventListener("astro:page-load", initAboutPageAnim);
</script>
