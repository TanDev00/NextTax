---
import { Icon } from 'astro-icon/components';
import MainLayout from '../../layouts/MainLayout.astro';
import { formatDate } from '../../lib/format';
import { getAllPosts, getPostBySlug } from '../../services/wordpress';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map(post => ({
    params: { slug: post.slug }
  }));
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug as string);

if (!post) {
  return new Response(null, {
    status: 404,
    statusText: 'Not found'
  });
}

const category = post.categories?.nodes?.[0]?.name || 'Tin tức';
const date = post.date ? formatDate(post.date) : '';
const image = post.featuredImage?.node?.sourceUrl || 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?auto=format&fit=crop&q=80&w=1200';
---

<MainLayout title={post.title || 'Bài viết'}>
  <article class="pt-32 pb-20">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto space-y-8">
        <div class="space-y-4">
          <div class="flex items-center gap-4 text-sm font-bold text-slate-400 uppercase tracking-widest">
            <span class="text-indigo-600">{category}</span>
            <span>•</span>
            <span>{date}</span>
          </div>
          <h1 class="text-4xl md:text-6xl leading-tight">{post.title}</h1>
        </div>

        <div class="aspect-video rounded-[2rem] overflow-hidden">
          <img src={image} alt={post.title} class="w-full h-full object-cover" />
        </div>

        <div class="prose prose-lg prose-indigo max-w-none text-slate-600 leading-relaxed space-y-6 wordpress-content" set:html={post.content} />

        <div class="pt-12 border-t border-slate-100 flex items-center justify-between">
          <a href="/blog" class="text-indigo-600 font-bold hover:underline flex items-center gap-2">
            <Icon name="lucide:arrow-left" class="w-4 h-4" /> Quay lại tin tức
          </a>
          <div class="flex gap-4">
            <button class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center hover:bg-indigo-600 hover:text-white transition-colors">
              <Icon name="lucide:facebook" class="w-4 h-4" />
            </button>
            <button class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center hover:bg-slate-800 hover:text-white transition-colors">
              <Icon name="lucide:twitter" class="w-4 h-4" />
            </button>
          </div>
        </div>
      </div>
    </div>
  </article>
</MainLayout>

<style is:global>
  /* Cải thiện hiển thị content WordPress */
  .wordpress-content img {
    border-radius: 1rem;
    height: auto;
  }
  .wordpress-content h2, .wordpress-content h3 {
    color: #1e293b;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .wordpress-content a {
    color: #4f46e5;
    text-decoration: underline;
  }
</style>
