---
export const prerender = true;

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

// Set caching headers for Vercel Edge Network
// Cache for 60 seconds, serve stale content while revalidating in background for 5 mins
Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

import { Icon } from 'astro-icon/components';
import MainLayout from '../../layouts/MainLayout.astro';
import { formatDate } from '../../lib/format';
import { getPostBySlug, getAllPosts } from '../../services/wordpress';

const { slug } = Astro.params;
const post = await getPostBySlug(slug as string);

if (!post) {
  return new Response(null, {
    status: 404,
    statusText: 'Not found'
  });
}

// Fetch recent posts for the sidebar, excluding the current post
const wpPosts = await getAllPosts();
const recentPosts = wpPosts.filter(p => p.slug !== slug).slice(0, 3);

const currentIndex = wpPosts.findIndex(p => p.slug === slug);
const prevPost = currentIndex < wpPosts.length - 1 ? wpPosts[currentIndex + 1] : null; // Older post
const nextPost = currentIndex > 0 ? wpPosts[currentIndex - 1] : null; // Newer post


const category = post.categories?.nodes?.[0]?.name || 'Tin tức';
const date = post.date ? formatDate(post.date) : '';
const image = post.featuredImage?.node?.sourceUrl || 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?auto=format&fit=crop&q=80&w=1200';
---

<MainLayout title={post.title || 'Bài viết'}>
  <article class="pt-32 pb-24">
    <div class="container xl:max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        
        <!-- Left Column (Main Content) -->
        <div class="lg:col-span-8 flex flex-col gap-6">
          
          <!-- Breadcrumb -->
          <div class="flex items-center gap-2 text-sm font-bold text-slate-800 flex-wrap">
            <a href="/" class="hover:text-[#f36a33] transition-colors">Home</a>
            <Icon name="lucide:chevron-right" class="w-4 h-4 text-slate-400" />
            <a href="/blog" class="hover:text-[#f36a33] transition-colors">Blog</a>
            <Icon name="lucide:chevron-right" class="w-4 h-4 text-slate-400" />
            <span class="text-slate-500 font-normal truncate max-w-[200px] md:max-w-md">{post.title}</span>
          </div>

          <!-- Featured Image -->
          <div class="w-full mt-4">
            <img src={image} alt={post.title} class="w-full h-auto object-cover" style="max-height: 500px;" />
          </div>

          <!-- Meta Bar (Matches image: Category | Date | Author | Comments) -->
          <div class="flex flex-wrap items-center gap-6 mt-4 text-sm text-slate-700 font-medium pb-6 border-b border-slate-100">
            <a href="#" class="text-slate-800 hover:text-[#f36a33] transition-colors">{category}</a>
            <span>{date}</span>
            <span class="flex items-center gap-1">
               {post.author?.node?.name || 'NextTax'}
            </span>
            <span class="text-slate-400">bình luận <span class="text-[#f36a33]">{post.comments?.nodes?.length || 0}</span></span>
          </div>

          <!-- Content Body -->
          <div class="prose porange-lg max-w-none text-slate-600 leading-relaxed wordpress-content mt-6 mb-12" set:html={post.content} />

          <!-- Post Navigation -->
          <div class="flex items-center justify-between py-10 border-t border-slate-100 mt-12">
            {prevPost ? (
              <a href={`/blog/${prevPost.slug}`} class="group flex items-center gap-2 font-bold text-slate-900 hover:text-[#f36a33] transition-colors relative pb-1">
                <Icon name="lucide:arrow-up-left" class="w-5 h-5 transition-transform group-hover:-translate-x-1 group-hover:-translate-y-1" />
                Bài viết trước
                <span class="absolute bottom-0 left-0 w-full h-[2px] bg-slate-900 group-hover:bg-[#f36a33] transition-colors"></span>
              </a>
            ) : <div></div>}
            
            {nextPost ? (
              <a href={`/blog/${nextPost.slug}`} class="group flex items-center gap-2 font-bold text-slate-900 hover:text-[#f36a33] transition-colors relative pb-1">
                Bài viết tiếp theo
                <Icon name="lucide:arrow-up-right" class="w-5 h-5 transition-transform group-hover:translate-x-1 group-hover:-translate-y-1" />
                <span class="absolute bottom-0 left-0 w-full h-[2px] bg-slate-900 group-hover:bg-[#f36a33] transition-colors"></span>
              </a>
            ) : <div></div>}
          </div>

          <!-- Comments Section (Dynamic from WordPress) -->
          <div class="pt-10">
            <h3 class="text-2xl font-bold text-slate-900 mb-8">
              {post.comments?.nodes?.length || 0} bình luận
            </h3>
            
            <div class="space-y-10">
              {(post.comments?.nodes || []).length > 0 ? (
                post.comments.nodes.map((comment, index) => (
                  <div class={`flex gap-6 ${index > 0 ? 'ml-0 md:ml-12' : ''}`}>
                    <!-- We use a default placeholder if avatar is missing from WPGraphQL -->
                    <img 
                      src={comment.author?.node?.avatar?.url || `https://ui-avatars.com/api/?name=${encodeURIComponent(comment.author?.node?.name || 'User')}&background=random`} 
                      alt="Avatar" 
                      class="w-16 h-16 object-cover bg-slate-100" 
                    />
                    <div class="flex-1">
                      <div class="flex items-baseline gap-4 mb-2">
                        <h4 class="text-lg font-bold text-slate-900">{comment.author?.node?.name || 'Anonymous'}</h4>
                        <span class="text-sm text-slate-400">{comment.date ? formatDate(comment.date) : ''}</span>
                      </div>
                      <div class="bg-gray-50/80 p-8 relative text-slate-600 leading-relaxed shadow-sm">
                        <!-- Triangle pointer -->
                        <div class="absolute w-4 h-4 bg-gray-50/80 rotate-45 -left-2 top-6"></div>
                        <div set:html={comment.content} />
                      </div>
                    </div>
                  </div>
                ))
              ) : (
                <p class="text-slate-500 italic">Chưa có bình luận nào cho bài viết này. Hãy là người đầu tiên!</p>
              )}
            </div>

            <!-- Leave a Reply Form -->
            <div class="mt-16 bg-white border border-slate-100 shadow-sm p-10">
              <h3 class="text-2xl font-bold text-slate-900 mb-8">Viết bình luận</h3>
              <form id="comment-form" data-post-id={post.databaseId} class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2" for="author">Tên của bạn *</label>
                    <input type="text" id="author" name="author" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 focus:outline-none focus:border-[#f36a33] focus:ring-1 focus:ring-[#f36a33] transition-colors" placeholder="Nguyễn Văn A" />
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2" for="email">Email *</label>
                    <input type="email" id="email" name="email" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 focus:outline-none focus:border-[#f36a33] focus:ring-1 focus:ring-[#f36a33] transition-colors" placeholder="email@example.com" />
                  </div>
                </div>
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2" for="content">Bình luận *</label>
                  <textarea id="content" name="content" required rows="5" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 focus:outline-none focus:border-[#f36a33] focus:ring-1 focus:ring-[#f36a33] transition-colors resize-y" placeholder="Nhập bình luận của bạn vào đây..."></textarea>
                </div>
                
                <div id="comment-status" class="hidden p-4 rounded-lg text-sm font-medium"></div>

                <button type="submit" id="submit-button" class="bg-[#f36a33] hover:bg-[#e05b26] text-white font-bold py-4 px-8 transition-colors flex items-center justify-center min-w-[150px]">
                  Gửi bình luận
                </button>
              </form>
            </div>
          </div>

        </div>

        <!-- Right Column (Sidebar) -->
        <aside class="lg:col-span-4 flex flex-col gap-10">
          
          <!-- Search Widget -->
          <div class="bg-[#f36a33] p-10">
            <h3 class="text-2xl font-bold text-white mb-6">Tìm kiếm</h3>
            <form action="/search" class="relative" method="GET">
              <input type="text" name="q" placeholder="Tìm kiếm..." class="w-full pl-6 pr-12 py-4 bg-white text-slate-800 focus:outline-none placeholder:text-slate-400" required />
              <button type="submit" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-800 hover:text-[#f36a33] transition-colors">
                <Icon name="lucide:search" class="w-5 h-5" />
              </button>
            </form>
          </div>

          <!-- Recent Posts Widget -->
          <div class="bg-gray-50/80 p-10">
            <h3 class="text-2xl font-bold text-slate-900 mb-8">Bài viết gần đây</h3>
            <div class="flex flex-col gap-6">
              {recentPosts.map((rp) => (
                <a href={`/blog/${rp.slug}`} class="flex items-center gap-4 group">
                  <div class="w-20 h-20 shrink-0 overflow-hidden bg-slate-200">
                    <img 
                      src={rp.featuredImage?.node?.sourceUrl || 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?auto=format&fit=crop&q=80&w=200'} 
                      alt={rp.title} 
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                    />
                  </div>
                  <div class="flex flex-col gap-1.5 flex-1">
                    <h4 class="font-bold text-slate-900 text-[15px] leading-snug group-hover:text-[#f36a33] transition-colors line-clamp-2">
                       {rp.title}
                    </h4>
                    <span class="text-xs text-slate-500">{rp.date ? formatDate(rp.date) : ''}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>

        </aside>

      </div>
    </div>
  </article>
</MainLayout>

<script>
  // Handle comment form submission
  const form = document.getElementById('comment-form') as HTMLFormElement;
  const statusEl = document.getElementById('comment-status');
  const btn = document.getElementById('submit-button') as HTMLButtonElement;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const postId = form.getAttribute('data-post-id');
      const author = (document.getElementById('author') as HTMLInputElement).value;
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const content = (document.getElementById('content') as HTMLTextAreaElement).value;

      if (!postId || !author || !email || !content) return;

      // Updating UI to loading state
      const originalBtnText = btn.innerHTML;
      btn.innerHTML = 'Đang gửi...';
      btn.disabled = true;
      btn.classList.add('opacity-75', 'cursor-not-allowed');
      statusEl?.classList.add('hidden');

      try {
        const res = await fetch('/api/comment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ postId, author, email, content })
        });

        const data = await res.json();

        if (res.ok && data.success) {
          // Success!
          if (statusEl) {
            statusEl.className = 'p-4 rounded-lg text-sm font-medium bg-green-50 text-green-700 border border-green-200 mt-4';
            statusEl.innerText = 'Bình luận của bạn đã được gửi thành công và đang chờ duyệt!';
          }
          form.reset();
        } else {
          // Error
          if (statusEl) {
            statusEl.className = 'p-4 rounded-lg text-sm font-medium bg-red-50 text-red-700 border border-red-200 mt-4';
            statusEl.innerText = data.error || 'Có lỗi xảy ra, vui lòng thử lại sau.';
          }
        }
      } catch (error) {
        if (statusEl) {
          statusEl.className = 'p-4 rounded-lg text-sm font-medium bg-red-50 text-red-700 border border-red-200 mt-4';
          statusEl.innerText = 'Không thể kết nối đến máy chủ.';
        }
      } finally {
        // Restore button state
        btn.innerHTML = originalBtnText;
        btn.disabled = false;
        btn.classList.remove('opacity-75', 'cursor-not-allowed');
      }
    });
  }
</script>

<style is:global>
  /* Cải thiện hiển thị content WordPress */
  .wordpress-content img {
    border-radius: 1rem;
    height: auto;
  }
  .wordpress-content h2, .wordpress-content h3 {
    color: #1e293b;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .wordpress-content a {
    color: #4f46e5;
    text-decoration: underline;
  }
</style>
