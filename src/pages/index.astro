---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/sections/home/Hero.astro";
import Services from "../components/sections/home/Services.astro";
import AboutPreview from "../components/sections/home/AboutPreview.astro";
import Testimonial from "../components/sections/home/Testimonial.astro";
import Partners from "../components/sections/home/Partners.astro";
import CTA from "../components/sections/home/CTA.astro";
import { getHomePageData } from "../services/wordpress";

const data = await getHomePageData();

if (!data) {
  return Astro.redirect('/404'); // Hoặc hiển thị thông báo lỗi
}
---

<MainLayout title="NextTax - Kế toán & Thuế thông minh">
  <Hero slides={data.heroSlides || []} />
  <Partners partners={data.partnersList || []} />
  <Services 
    badge={data.servicesSection?.badge} 
    title={data.servicesSection?.title} 
    services={data.servicesSection?.list || []} 
  />
  <AboutPreview 
    badge={data.aboutSection?.badge}
    title={data.aboutSection?.title}
    image={data.aboutSection?.image?.node?.sourceUrl}
    heading={data.aboutSection?.heading}
    content={data.aboutSection?.content}
    signature={data.aboutSection?.signature?.node?.sourceUrl}
    stats={data.aboutSection?.stats || []}
  />
  <CTA 
    heading={data.ctaSection?.heading}
    description={data.ctaSection?.description}
    background={data.ctaSection?.background?.node?.sourceUrl}
  />
  <Testimonial 
    badge={data.testimonialSection?.badge}
    title={data.testimonialSection?.title}
    testimonials={data.testimonialSection?.list || []}
  />
</MainLayout>
