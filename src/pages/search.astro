---
import MainLayout from "../layouts/MainLayout.astro";
import { Icon } from "astro-icon/components";
import { WORDPRESS_API_URL } from "../lib/constants";

const title = "Kết quả tìm kiếm";
---

<MainLayout title={title}>
  <section class="py-20 bg-slate-50 min-h-[70vh]">
    <div class="container mx-auto px-6">
      <!-- Breadcrumbs -->
      <nav class="flex mb-6 text-sm text-slate-500 gap-2 items-center">
        <a href="/" class="hover:text-orange-600 transition-colors font-medium"
          >Trang chủ</a
        >
        <Icon name="lucide:chevron-right" class="w-4 h-4" />
        <span>Tìm kiếm</span>
      </nav>

      <div class="mb-12">
        <h1
          class="text-4xl md:text-5xl font-black text-slate-900 tracking-tight"
          id="search-title"
        >
          Tìm kiếm
        </h1>
        <p class="mt-4 text-slate-500 text-lg" id="search-count">
          Đang tìm kiếm dữ liệu...
        </p>
      </div>

      <!-- Loading State -->
      <div
        id="search-loading"
        class="flex flex-col items-center justify-center py-20 space-y-4"
      >
        <div
          class="w-12 h-12 border-4 border-orange-600/20 border-t-orange-600 rounded-full animate-spin"
        >
        </div>
        <span class="text-slate-500 font-medium"
          >Vui lòng đợi trong giây lát...</span
        >
      </div>

      <!-- Results Grid -->
      <div
        id="results-grid"
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 hidden"
      >
        <!-- Dynamically injected cards -->
      </div>

      <!-- Empty State -->
      <div
        id="empty-state"
        class="bg-white rounded-md p-16 text-center border-2 border-dashed border-slate-200 hidden"
      >
        <div
          class="w-24 h-24 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-8 shadow-inner"
        >
          <Icon name="lucide:search-x" class="w-12 h-12 text-slate-400" />
        </div>
        <h2 class="text-2xl font-bold text-slate-900 mb-4">
          Không tìm thấy kết quả nào
        </h2>
        <p class="text-slate-500 mb-10 max-w-md mx-auto text-lg">
          Chúng tôi không tìm thấy nội dung nào phù hợp với từ khóa của bạn. Hãy
          thử lại với một từ khóa khác.
        </p>
        <button
          onclick="window.dispatchEvent(new CustomEvent('toggle-search'))"
          class="inline-flex items-center justify-center px-10 py-5 bg-orange-600 text-white font-bold rounded-2xl hover:bg-orange-700 transition-all shadow-xl shadow-orange-200 active:scale-95"
        >
          <Icon name="lucide:search" class="w-5 h-5 mr-3" /> Thử tìm kiếm lại
        </button>
      </div>
    </div>
  </section>
</MainLayout>

<script is:inline define:vars={{ WORDPRESS_API_URL }}>
  async function performSearch() {
    const params = new URLSearchParams(window.location.search);
    const query = params.get("q") || "";

    const titleEl = document.getElementById("search-title");
    const countEl = document.getElementById("search-count");
    const loadingEl = document.getElementById("search-loading");
    const gridEl = document.getElementById("results-grid");
    const emptyEl = document.getElementById("empty-state");

    if (!query) {
      titleEl.innerText = "Vui lòng nhập từ khóa";
      countEl.innerText = "";
      loadingEl.classList.add("hidden");
      emptyEl.classList.remove("hidden");
      return;
    }

    titleEl.innerHTML = `Kết quả cho: <span class="text-orange-600">"${query}"</span>`;

    try {
      console.log("Starting search for:", query);
      const response = await fetch(WORDPRESS_API_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          query: `
            query SearchAll($search: String!) {
              posts(first: 30, where: { search: $search }) {
                nodes {
                  id
                  title
                  slug
                  date
                  excerpt
                  featuredImage {
                    node {
                      sourceUrl
                      altText
                    }
                  }
                  categories {
                    nodes {
                      name
                    }
                  }
                }
              }
              services(first: 20, where: { search: $search }) {
                nodes {
                  id
                  title
                  slug
                }
              }
            }
          `,
          variables: { search: query },
        }),
      });

      const result = await response.json();
      console.log("Search Raw Result:", result);

      if (result.errors) {
        throw new Error(result.errors[0].message);
      }

      const data = result.data;

      const blogPosts = data?.posts?.nodes || [];
      const services = (data?.services?.nodes || []).map((s) => ({
        ...s,
        isService: true,
        slug: `services/${s.slug}`,
        date: new Date().toISOString(),
      }));

      const allResults = [...blogPosts, ...services];
      console.log("Combined Results:", allResults);

      loadingEl.classList.add("hidden");

      if (allResults.length === 0) {
        countEl.innerText = "Tìm thấy 0 kết quả phù hợp.";
        emptyEl.classList.remove("hidden");
        gridEl.classList.add("hidden");
      } else {
        countEl.innerText = `Tìm thấy ${allResults.length} kết quả phù hợp.`;
        gridEl.innerHTML = "";
        allResults.forEach((post) => {
          const card = createCard(post);
          gridEl.appendChild(card);
        });
        gridEl.classList.remove("hidden");
      }
    } catch (error) {
      console.error("Search Critical Error:", error);
      loadingEl.classList.add("hidden");
      countEl.innerText = "Đã xảy ra lỗi khi kết nối với máy chủ.";
      emptyEl.innerHTML = `
        <div class="text-red-500 font-bold mb-4">Lỗi kết nối API WordPress</div>
        <p class="text-slate-500 mb-6">${error.message}</p>
        <button onclick="location.reload()" class="bg-orange-600 text-white px-6 py-2 rounded-lg font-bold">Thử lại</button>
      `;
      emptyEl.classList.remove("hidden");
    }
  }

  function createCard(post) {
    const div = document.createElement("article");
    div.className =
      "bg-white rounded-md overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 group border border-slate-100 flex flex-col h-full";

    const imageUrl = post.featuredImage?.node?.sourceUrl || "";
    const date = new Date(post.date).toLocaleDateString("vi-VN", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });

    const category = post.isService
      ? "Dịch vụ"
      : post.categories?.nodes?.[0]?.name || "Tin tức";
    const categoryColor = post.isService ? "bg-orange-600" : "bg-orange-600";
    const link = post.isService ? `/${post.slug}` : `/blog/${post.slug}`;

    div.innerHTML = `
      <a href="${link}" class="block aspect-[16/10] overflow-hidden relative">
        ${
          imageUrl
            ? `
          <img src="${imageUrl}" alt="${post.title}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
        `
            : `
          <div class="w-full h-full bg-slate-100 flex items-center justify-center">
            <svg class="w-12 h-12 text-slate-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
          </div>
        `
        }
        <span class="absolute top-4 left-4 ${categoryColor} text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
          ${category}
        </span>
      </a>
      <div class="p-8 flex-1 flex flex-col">
        ${!post.isService ? `<time class="text-slate-400 text-sm font-medium mb-3 block">${date}</time>` : ""}
        <h2 class="text-xl font-bold text-slate-900 mb-4 group-hover:text-orange-600 transition-colors line-clamp-2">
          <a href="${link}">${post.title}</a>
        </h2>
        <div class="text-slate-500 text-sm line-clamp-3 mb-6 flex-1">${post.excerpt || ""}</div>
        <a href="${link}" class="inline-flex items-center text-orange-600 font-bold hover:gap-2 transition-all">
          Xem chi tiết <svg class="w-4 h-4 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    `;
    return div;
  }

  // Load search on mount
  performSearch();

  // Re-run if URL changes without page reload (for some SPA scenarios or popstate)
  window.addEventListener("popstate", performSearch);
</script>
